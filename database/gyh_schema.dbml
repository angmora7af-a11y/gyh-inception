// ============================================================
// G&H OBRAS Y ESTRUCTURAS METALICAS S.A.S
// Sistema de Gestión Comercial, Cotizaciones, Inventarios y Facturación
// Base de Datos: PostgreSQL — Versión 1.1
// Fecha: 2026-07-04 (actualizado SEM-27 con entrevistas de feedback)
// ============================================================

Project gyh_sistema {
  database_type: 'PostgreSQL'
  Note: '''
    Sistema de Gestión para G&H Obras y Estructuras Metálicas S.A.S.
    NIT: 901.218.896-8 — Bogotá, Colombia
    Módulos: Clientes · Cotizaciones · Contratos · Inventarios · Facturación · Auditoría
    Métricas de escala: ~180 clientes, hasta 50 obras/cliente, 3-4 frentes/obra,
    6-12 cotizaciones/semana por dibujante, ~50 prospectos nuevos/mes.
    SEM-27: Pedidos parciales · Centros de costo · Retenciones por tipo · Catálogos duales
            Rol Despachador · Rol Recepción · CUFE/Radian · Equipo ajeno · Cronograma diario
    Feedback fotos: Vehículos con dimensiones + placa · Kardex movimientos · 6 tablas reportería
                    Relaciones cliente→obra→frente en tablas clave · URLs en documentos · 12 roles
                    Dimensiones ítem remisión (LARGO/ANCHO/ALTO/PESO) · Condición BUENO/REGULAR/MALO
  '''
}

// ============================================================
// ENUMERACIONES GLOBALES
// ============================================================

Enum rol_usuario {
  superadmin       [note: 'Configuración global del sistema — parámetros de trayecto, reglas de negocio, tarifas']
  admin            [note: 'Administrador del sistema']
  comercial        [note: 'Equipo de ventas y cotizaciones; incluye ingenieros de campo; autoriza despachos']
  dibujante        [note: 'Modelamiento técnico en AutoCAD']
  contabilidad     [note: 'Validación financiera y supervisión de cartera']
  facturacion      [note: 'Genera facturas y proformas, envía a Siigo/DIAN, gestiona centros de costo y retenciones']
  juridica         [note: 'Validación documental y contratos']
  almacen          [note: 'Jefe de almacén, inventarios y agenda de transporte']
  conductor        [note: 'Transporte de equipos']
  despachador      [note: 'Conteo físico de equipos en bodega (entrada y salida); clasifica estado en devoluciones']
  recepcion        [note: 'Cronograma diario de recogidas y cortes — Viviana']
  soporte_atencion [note: 'Soporte atención al cliente — registra nuevos clientes con documentación; consulta inventarios para informar disponibilidad; NO aprueba clientes ni ve información financiera']
}

Enum tipo_id {
  NIT
  CC
  CE
  Pasaporte
}

Enum ciudad_sucursal {
  bogota
  ibague
  armenia
}

Enum estado_cliente {
  prospecto     [note: 'Lead sin proceso de registro formal']
  en_revision   [note: 'Checklist en proceso de aprobación']
  aprobado      [note: 'Todos los conceptos favorables']
  rechazado     [note: 'Al menos un área dio concepto no favorable']
  inactivo
}

Enum regimen_iva_tipo {
  comun
  simplificado
  especial
}

Enum area_aprobacion {
  contabilidad
  juridica
  comercial
}

Enum estado_aprobacion {
  pendiente
  favorable
  no_favorable
}

Enum tipo_contacto {
  encargado_pagos
  recepcion_facturas
  general
}

Enum tipo_documento_registro {
  rut
  camara_comercio
  cedula_representante
  estados_financieros
  autorizacion_centrales_riesgo
  formulario_registro_ft_ac_001
  carta_presentacion
  certificado_bancario
  otro
}

Enum estado_validacion_doc {
  pendiente
  aprobado
  rechazado
  requiere_actualizacion
}

Enum estado_obra {
  activa
  pausada
  finalizada
  cancelada
}

Enum tipo_producto {
  formaleta_tradicional [note: 'Línea FT — parales, cerchas, crucetas, andamio tubular, andamio colgante; prefijo remisión FT']
  formaleta_metalica    [note: 'Línea FM — tableros (múltiples medidas), rinconeras, ángulos, corbatas; prefijo remisión FM']
  multidireccional      [note: 'Línea AMD — verticales con/sin espigo, horizontales, diagonales, tornillo nivelador; sistema ALFOR/AMD']
  andamio_alfor         [note: 'Sistema de andamio ALFOR — abrazaderas, alineadores, bases, cruces, plataformas; prefijo ALFOR']
  consumible            [note: 'Materiales de bodega — pintura, disolvente/thinner, soldadura 6013, soldadura MIG, tornillos, gases; no se alquila']
  maquinaria            [note: 'Equipos de maquinaria y herramienta mayor']
  accesorio             [note: 'Accesorios y piezas complementarias de cualquier línea']
  otro                  [note: 'Otros productos no clasificados']
}

Enum unidad_medida {
  unidad
  metro
  metro_cuadrado
  juego
  kit
}

Enum bodega_id {
  bodega_1  [note: 'Bodega 1 — Engativá — Principal de almacenamiento']
  bodega_2  [note: 'Bodega 2 — Luz — Almacenamiento secundario']
  bodega_40 [note: 'Bodega 40 — Mantenimiento — Equipo en reparación']
  bodega_50 [note: 'Bodega 50 — Clientes — Equipo en poder de clientes (alquilado)']
}

Enum estado_cotizacion {
  borrador
  en_revision
  enviada_cliente
  aprobada_cliente
  rechazada_cliente
  vencida
  convertida_orden
}

Enum tipo_item_cotizacion {
  venta         [note: 'Productos existentes en catálogo']
  alquiler      [note: 'Maquinaria temporal — se calcula por días desde pedido completo']
  transporte_ida
  transporte_vuelta
  reposicion    [note: 'Cobro por pérdida o no devolución']
  accesorio
}

Enum formato_archivo {
  dwg
  dxf
  pdf
  xlsx
  xls
  png
  jpg
}

Enum tipo_archivo_plano {
  plano_autocad
  desglose_materiales
  cotizacion_pdf
  otro
}

Enum estado_orden {
  pendiente
  en_firma
  activa
  finalizada
  cancelada
}

Enum estado_contrato {
  borrador
  enviado_firma
  firmado
  cancelado
}

Enum tipo_remision {
  salida             [note: 'Despacho de equipos a obra']
  entrada_devolucion [note: 'Retorno de alquiler']
  entrada_reposicion [note: 'Cobro por faltante']
  cambio             [note: 'Intercambio o sustitución de equipo en obra']
  entrada_mantenimiento [note: 'Retorno de equipo para mantenimiento en G&H']
}

Enum condicion_equipo_devolucion {
  bueno   [note: 'Equipo en buen estado — apto para despacho inmediato']
  regular [note: 'Equipo con desgaste normal — funcional pero requiere revisión']
  malo    [note: 'Equipo muy deteriorado — requiere mantenimiento o baja']
}

Enum estado_remision {
  programada
  en_transito
  entregada
  recibida
  con_novedad
}

Enum estado_item_remision {
  pendiente
  entregado_ok
  entregado_parcial
  danado         [note: 'Daño que genera novedad y posible cobro al cliente']
  baja           [note: 'Equipo dado de baja — destrucción irreparable o pérdida definitiva; se registra internamente, no genera reposición']
  mantenimiento  [note: 'Equipo reparable — G&H asume el costo, no se factura al cliente']
  faltante       [note: 'No retornó — genera ítem de reposición (cobro al cliente según catálogo)']
  ajeno          [note: 'Equipo que no pertenece a G&H — devolver a empresa externa']
}

Enum proveedor_transporte {
  gyh     [note: 'G&H provee y factura el transporte — cobro por peso Y volumen (el que resulte mayor)']
  cliente [note: 'El cliente gestiona su propio transporte — no se cobra flete por G&H']
}

Enum tipo_origen_contrato {
  interno  [note: 'Contrato ya existente con el cliente — activa operaciones directamente sin firma']
  externo  [note: 'Nuevo contrato para cliente externo o primer contrato — requiere firma Ooku']
}

Enum ciclo_cobro {
  mes_vencido  [note: 'Cobro el mes siguiente al período del servicio (default)']
  quincenal
  semanal
  al_cierre    [note: 'Facturación al cierre de la obra']
}

Enum estado_agenda {
  programado
  en_curso
  completado
  cancelado
  reprogramado
}

Enum estado_factura {
  pendiente
  enviada
  pagada_parcial
  pagada
  vencida
  en_cartera
  anulada
}

Enum metodo_pago {
  transferencia
  efectivo
  cheque
  otro
}

Enum estado_cartera {
  nueva
  en_gestion
  acuerdo_pago
  demanda
  castigada
  recuperada
}

Enum tipo_notificacion {
  aprobacion_pendiente
  cotizacion_aprobada
  contrato_firmado
  recogida_programada
  devolucion_pendiente
  factura_vencida
  cartera_alerta
  sistema
}

// Nuevos enums SEM-27 ────────────────────────────────────────

Enum estado_pedido {
  pendiente   [note: 'Sin remisiones de salida generadas aún']
  parcial     [note: 'Con al menos una remisión, pedido incompleto — el alquiler NO ha iniciado']
  completo    [note: 'Todo el pedido fue despachado — inicia contador de días de alquiler']
  cancelado   [note: 'Cancelado por la obra; motivo registrado']
}

Enum modalidad_factura {
  por_remision  [note: 'Una factura por cada remisión o contratista']
  consolidada   [note: 'Una sola factura con todos los ítems del período (transporte siempre va separado)']
  por_valor     [note: 'El usuario define el monto; el sistema agrega ítems hasta alcanzarlo']
}

Enum estado_radian {
  sin_enviar
  enviada_dian    [note: 'Enviada a la DIAN — CUFE generado']
  aceptada_dian   [note: 'Aceptada y marcada por el cliente con sistema contable (triple check)']
  rechazada_dian  [note: 'Rechazada por la DIAN — revisar errores']
  sin_confirmar   [note: 'Cliente con dominio público (Gmail/Hotmail) — no dará check automático; Cartera llama']
}

Enum tipo_dominio_correo {
  corporativo  [note: 'Sistema contable propio — da triple check automático en DIAN']
  publico      [note: 'Gmail, Hotmail, Yahoo — nunca dará el check; seguimiento telefónico por Cartera']
}

// ============================================================
// MÓDULO: USUARIOS Y SEGURIDAD
// ============================================================

Table usuarios {
  id          uuid        [pk, default: `gen_random_uuid()`]
  nombre      varchar(200) [not null]
  email       varchar(200) [unique, not null]
  password_hash varchar(500) [not null]
  rol         rol_usuario  [not null]
  activo      boolean      [default: true]
  created_at  timestamp    [default: `now()`]
  updated_at  timestamp    [default: `now()`]

  Note: 'Usuarios del sistema con control de acceso por rol (RBAC) — 12 roles'
}

// ============================================================
// MÓDULO: AUDITORÍA Y NOTIFICACIONES (Transversal)
// ============================================================

Table auditoria {
  id               bigserial    [pk]
  usuario_id       uuid         [ref: > usuarios.id]
  accion           varchar(100) [not null, note: 'CREATE, UPDATE, DELETE, LOGIN, etc.']
  tabla_afectada   varchar(100) [not null]
  registro_id      varchar(100) [note: 'ID del registro modificado']
  datos_anteriores jsonb
  datos_nuevos     jsonb
  ip_address       varchar(50)
  user_agent       text
  created_at       timestamp    [default: `now()`]

  indexes {
    usuario_id
    tabla_afectada
    created_at
  }

  Note: 'Log inmutable: quién hizo qué y cuándo — requerimiento transversal del sistema'
}

Table notificaciones {
  id               bigserial    [pk]
  usuario_id       uuid         [not null, ref: > usuarios.id]
  tipo             tipo_notificacion [not null]
  titulo           varchar(300) [not null]
  mensaje          text         [not null]
  url_referencia   varchar(500)
  leida            boolean      [default: false]
  leida_at         timestamp
  created_at       timestamp    [default: `now()`]

  indexes {
    usuario_id
    leida
  }

  Note: 'Motor de notificaciones para empujar aprobaciones y alertas logísticas'
}

// ============================================================
// MÓDULO: CLIENTES
// (Basado en formulario FT-AC-001 VERSION 2.0)
// ============================================================

Table clientes {
  id                      uuid        [pk, default: `gen_random_uuid()`]

  // I. INFORMACIÓN GENERAL (FT-AC-001 Sección I)
  razon_social            varchar(300) [not null]
  nombre_comercial        varchar(300)
  tipo_identificacion     tipo_id      [not null]
  numero_identificacion   varchar(50)  [unique, not null]
  ciudad                  varchar(100)
  direccion               text
  telefono                varchar(50)
  fax                     varchar(50)
  representante_legal     varchar(200)
  id_representante        varchar(50)
  clase_sociedad          varchar(100)
  regimen                 varchar(100)

  // V. INFORMACIÓN TRIBUTARIA (FT-AC-001 Sección V)
  tiene_camara_comercio   boolean      [default: false]
  fecha_camara_comercio   date
  matricula_camara        varchar(100)
  codigo_ciiu             varchar(20)
  actividad_economica     text
  codigo_ica              varchar(20)
  tarifa_ica              decimal(5,2)
  rte_fuente              decimal(5,2)
  rte_ica                 decimal(5,2)
  regimen_iva             regimen_iva_tipo
  gran_contribuyente      boolean      [default: false]
  autorretenedor          boolean      [default: false]

  // Facturación especial (SEM-27)
  nombre_facturacion      varchar(300) [note: 'Nombre para la factura cuando el pagador difiere del contratante (ej: fiducia vs. consorcio Bronz)']
  tipo_dominio_correo     tipo_dominio_correo [note: 'Corporativo = triple check DIAN automático; Público = seguimiento telefónico por Cartera']
  tiene_sistema_contable  boolean      [default: false, note: 'Define si el cliente puede dar el triple check en DIAN o requiere llamada']

  // Condiciones de pago (SEM-27)
  dias_tramitacion_facturas integer     [note: 'Días específicos del cliente para tramitar facturas (ej: paga solo los martes)']
  ciclo_cobro               ciclo_cobro [default: 'mes_vencido', note: 'Ciclo de cobro: mes vencido es el default']
  notas_condiciones_pago    text        [note: 'Instrucciones especiales de facturación (horarios, contacto, portal específico)']

  // Control del sistema
  estado_cliente          estado_cliente [default: 'prospecto']
  codigo_revision         varchar(50)  [unique, note: 'Código auto-generado de revisión del registro']
  ciudad_sucursal         ciudad_sucursal
  creado_por              uuid         [ref: > usuarios.id]
  created_at              timestamp    [default: `now()`]
  updated_at              timestamp    [default: `now()`]

  indexes {
    numero_identificacion
    estado_cliente
    ciudad_sucursal
  }

  Note: 'Registro central de clientes — ~180 clientes migración inicial (130 Bogotá, 50 Ibagué/Armenia)'
}

Table contactos_cliente {
  id             uuid         [pk, default: `gen_random_uuid()`]
  cliente_id     uuid         [not null, ref: > clientes.id]

  // II. INFORMACIÓN DE CONTACTO (FT-AC-001 Sección II)
  tipo_contacto  tipo_contacto [not null]
  nombre         varchar(200) [not null]
  telefono       varchar(50)
  ext            varchar(10)
  correo         varchar(200)
  direccion      text
  horario        varchar(200)
  plazos_pago    varchar(200)

  Note: 'Sección II FT-AC-001: encargado de pagos y recepción de facturas electrónicas'
}

Table referencias_bancarias {
  id               uuid         [pk, default: `gen_random_uuid()`]
  cliente_id       uuid         [not null, ref: > clientes.id]

  // III. REFERENCIAS BANCARIAS (FT-AC-001 Sección III)
  banco            varchar(200) [not null]
  sucursal         varchar(200)
  telefono         varchar(50)
  direccion        text
  persona_contacto varchar(200)
  orden            integer      [default: 1]

  Note: 'Sección III FT-AC-001: hasta 2 referencias bancarias por cliente'
}

Table referencias_comerciales {
  id         uuid         [pk, default: `gen_random_uuid()`]
  cliente_id uuid         [not null, ref: > clientes.id]

  // IV. REFERENCIAS COMERCIALES (FT-AC-001 Sección IV)
  nombre     varchar(200) [not null]
  telefono   varchar(50)
  celular    varchar(50)
  direccion  text
  orden      integer      [default: 1]

  Note: 'Sección IV FT-AC-001: hasta 2 referencias comerciales por cliente'
}

Table accionistas {
  id              uuid         [pk, default: `gen_random_uuid()`]
  cliente_id      uuid         [not null, ref: > clientes.id]

  // VII. SOCIOS Y/O ACCIONISTAS (FT-AC-001 Sección VII)
  nombre_completo varchar(300) [not null]
  tipo_id         tipo_id      [not null]
  numero_id       varchar(50)  [not null]
  es_pep          boolean      [default: false, note: 'Persona Expuesta Políticamente']
  descripcion_pep text

  Note: 'Sección VII FT-AC-001: accionistas con >5% del capital social'
}

Table autorizacion_centrales_riesgo {
  id                    uuid    [pk, default: `gen_random_uuid()`]
  cliente_id            uuid    [unique, not null, ref: > clientes.id]
  firma_representante_url varchar(500)
  huella_url            varchar(500)
  fecha_firma           date
  nombre_firmante       varchar(200)
  cedula_firmante       varchar(50)

  Note: 'Autorización Ley 1581/2012 — Consulta centrales de riesgo y listas LAFT (Circular 09/2016)'
}

// ============================================================
// FLUJO DE APROBACIÓN DE CLIENTES
// ============================================================

Table aprobaciones_cliente {
  id             uuid         [pk, default: `gen_random_uuid()`]
  cliente_id     uuid         [not null, ref: > clientes.id]
  area           area_aprobacion [not null]
  estado         estado_aprobacion [default: 'pendiente']
  concepto       text         [note: 'Comentario obligatorio que justifica la decisión — no se puede guardar sin él']
  es_favorable   boolean      [note: 'true=favorable · false=no_favorable · null=aún sin concepto']
  evidencia_url  varchar(500) [note: 'URL del documento adjunto como evidencia del concepto (S3)']
  aprobado_por   uuid         [ref: > usuarios.id]
  fecha_concepto timestamp
  created_at     timestamp    [default: `now()`]
  updated_at     timestamp    [default: `now()`]

  indexes {
    (cliente_id, area) [unique, note: 'Un concepto por área por cliente']
  }

  Note: 'Checklist digital de aprobación: las 3 áreas deben dar concepto antes de proceder al contrato'
}

Table documentos_registro {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  cliente_id          uuid    [not null, ref: > clientes.id]
  tipo_documento      tipo_documento_registro [not null]
  nombre_archivo      varchar(300) [not null]
  url_archivo         varchar(500) [not null]
  estado_validacion   estado_validacion_doc [default: 'pendiente']
  validado_por        uuid    [ref: > usuarios.id]
  fecha_validacion    timestamp
  comentario          text
  uploaded_by         uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]

  Note: 'Documentos del checklist de validación: RUT, Cámara, Cédula RL, Estados Financieros, etc.'
}

// ============================================================
// MÓDULO: OBRAS Y FRENTES DE TRABAJO
// ============================================================

Table obras {
  id         uuid         [pk, default: `gen_random_uuid()`]
  cliente_id uuid         [not null, ref: > clientes.id]

  // VIII. INFORMACIÓN DE OBRA (FT-AC-001 Sección VIII)
  nombre     varchar(300) [not null]
  direccion  text         [not null]
  ciudad     varchar(100)
  telefono   varchar(50)
  correo     varchar(200)
  encargado  varchar(200)
  estado     estado_obra  [default: 'activa']
  created_at timestamp    [default: `now()`]
  updated_at timestamp    [default: `now()`]

  indexes {
    cliente_id
    estado
  }

  Note: 'Obras por cliente — hasta 50 por cliente según métricas de migración'
}

Table frentes_obra {
  id          uuid         [pk, default: `gen_random_uuid()`]
  obra_id     uuid         [not null, ref: > obras.id]
  nombre      varchar(200) [not null]
  descripcion text
  estado      estado_obra  [default: 'activa']
  created_at  timestamp    [default: `now()`]

  Note: 'Frentes dentro de una obra — entre 3 y 4 frentes por obra; el equipo se puede prestar entre frentes'
}

// ============================================================
// MÓDULO: CATÁLOGO DE PRODUCTOS
// ============================================================

Table catalogo_productos {
  id                   uuid         [pk, default: `gen_random_uuid()`]
  codigo               varchar(100) [unique, not null]
  nombre               varchar(300) [not null]
  descripcion          text
  categoria            varchar(100)
  tipo_producto        tipo_producto [not null]
  unidad_medida        unidad_medida [default: 'unidad']

  // Conversión de unidades para facturación (nuevo - julio 2026)
  unidad_kardex        varchar(10)   [note: 'Unidad en la que se registra en kardex (ej: und, unidad)']
  unidad_facturacion   varchar(10)   [note: 'Unidad en la que se factura (ej: m2, und) — puede diferir de unidad_kardex']
  largo_m              decimal(8,3)  [note: 'Largo del producto en metros — para conversión automática a m²']
  ancho_m              decimal(8,3)  [note: 'Ancho del producto en metros — para conversión automática a m²']
  alto_m               decimal(8,3)  [note: 'Alto del producto en metros']

  // Precios por modalidad (catálogo general anual — actualizado por Recepción)
  precio_venta         decimal(15,2)
  precio_alquiler_dia  decimal(15,2) [note: 'Tarifa diaria — inicia desde fecha de pedido completo hasta devolución']
  precio_reposicion    decimal(15,2) [note: 'Valor comercial en caso de pérdida/daño irreparable']

  // Cálculo por área
  calcula_por_m2       boolean       [default: false]
  precio_por_m2        decimal(15,2)

  // Clasificación facturación (SEM-27)
  centro_costo         varchar(5)    [note: '13=alquiler · 14=venta_reposicion — aplicado automáticamente en factura']
  unidad_negocio       varchar(50)   [note: 'formaleta_metalica|multidireccional|transporte|formaleta_plastica|formaleta_tradicional']
  codigo_tipo          varchar(10)   [note: 'alquiler|venta — no mezclar; al hacer venta no tomar de inventario de alquiler']
  precio_transporte_calculo varchar(20) [note: 'peso_volumen|toneladas — el cobro real de transporte es por lo que ocupe (peso O volumen que llene el camión)']

  // Peso físico del equipo (fuente: PESO-EQUIPOS-GYH — tablas PESO FT, PESO FM, PESOS EQUI-ALFOR, PESO FT)
  peso_kg_unitario     decimal(10,3) [note: 'Peso unitario en kg — base para cálculo automático de flete por tonelada en remisiones; tabla fuente: PESO-EQUIPOS-GYH.xlsx']

  // Dimensiones físicas del ítem (para cálculo de volumen de carga — flete por volumen)
  largo_m_ref          decimal(8,3)  [note: 'Largo de referencia del producto en metros — para estimación volumétrica en despachos']
  ancho_m_ref          decimal(8,3)  [note: 'Ancho de referencia en metros']
  alto_m_ref           decimal(8,3)  [note: 'Alto de referencia en metros']

  // Inventario
  stock_actual         integer       [default: 0]
  stock_minimo         integer       [default: 0]
  stock_maximo         integer       [note: 'Nivel máximo deseable — aplica también en kardex_consumibles para materiales']

  imagen_url           varchar(500)
  activo               boolean       [default: true]
  codigo_revision      varchar(50)   [note: 'Código auto de versión del producto']
  created_at           timestamp     [default: `now()`]
  updated_at           timestamp     [default: `now()`]

  Note: 'Catálogo general anual — actualizado por Recepción cada año y distribuido a todas las áreas. Incluye peso_kg_unitario obligatorio para líneas FT/FM/AMD/ALFOR (fuente: PESO-EQUIPOS-GYH.xlsx). Consumibles (tipo_producto=consumible) usan kardex_consumibles, no kardex_movimientos'
}

// Precios especiales por cliente (SEM-27)
Table catalogo_precios_cliente {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  cliente_id          uuid    [not null, ref: > clientes.id]
  producto_id         uuid    [not null, ref: > catalogo_productos.id]
  precio_alquiler_dia decimal(15,2)
  precio_venta        decimal(15,2)
  precio_reposicion   decimal(15,2)
  vigente_desde       date    [not null]
  vigente_hasta       date
  acuerdo_comercial   text    [not null, note: 'Descripción del acuerdo — notificado por escrito a Facturación por el Comercial']
  registrado_por      uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]
  updated_at          timestamp [default: `now()`]

  indexes {
    (cliente_id, producto_id)
    vigente_desde
  }

  Note: 'Precios especiales por cliente — el Comercial los acuerda y notifica por escrito a Facturación (ej: Marval con 30 obras)'
}

// Configuración de retenciones por tipo de concepto (SEM-27)
Table retenciones_config {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  tipo_concepto       varchar(30) [not null, note: 'alquiler|transporte|venta|reposicion']
  nombre_retencion    varchar(30) [not null, note: 'rte_fuente|rte_ica|iva']
  porcentaje          decimal(5,2) [not null]
  centro_costo        varchar(5)  [note: '13=alquiler · 14=venta_reposicion']
  vigente_desde       date    [not null]
  vigente_hasta       date
  nota                text    [note: 'Ej: Transporte Rte. Fuente 1% — diferente de alquiler; no mezclar en una factura o Siigo la rechaza']
  creado_por          uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]

  Note: 'Retenciones por tipo de concepto — transporte y alquiler tienen tasas distintas; si se mezclan, Siigo rechaza la factura'
}

// Configuración de tarifas de transporte por zona (SEM-27 + Análisis docs PESO-EQUIPOS)
Table config_tarifas_transporte {
  id               uuid    [pk, default: `gen_random_uuid()`]
  zona             varchar(50)  [not null, note: 'bogota|fuera_bogota|ibague|armenia|otro — corresponde a ciudad_sucursal o destino de la obra']
  tarifa_por_ton   decimal(10,2) [not null, note: 'Valor en COP por tonelada — Bogotá: $2.500, Fuera de Bogotá: $4.500 (fuente: PESO-EQUIPOS-GYH.xlsx hoja CONSOLIDADO)']
  tarifa_por_m3    decimal(10,2) [note: 'Valor por metro cúbico si el cálculo es por volumen (aplica cuando el camión va lleno en volumen pero no en toneladas)']
  tipo_calculo     varchar(20)  [not null, default: 'mayor_valor', note: 'mayor_valor=se cobra el mayor entre peso_ton y volumen_m3; solo_ton; solo_m3']
  tipo_camion      varchar(50)  [note: 'NULL=aplica a todos; o especificar tipo: furgon|camion|camioneta — para diferencial de tarifa por flota']
  vigente_desde    date    [not null]
  vigente_hasta    date
  creado_por       uuid    [ref: > usuarios.id]
  created_at       timestamp [default: `now()`]

  indexes {
    zona
    vigente_desde
  }

  Note: 'Tarifas de transporte configurables por SuperAdmin — fuente: planilla PESO-EQUIPOS-GYH.xlsx (CONSOLIDADO): Bogotá $2.500/ton, Fuera $4.500/ton. Se cobra el mayor entre peso real y volumen ocupado del camión'
}

// Criterios de bonificación en liquidación de conductores (fuente: hoja CONSOLIDADO de PESO-EQUIPOS-GYH.xlsx)
Table config_criterios_liquidacion_conductor {
  id               uuid    [pk, default: `gen_random_uuid()`]
  codigo           varchar(10)  [unique, not null, note: 'MP|RTE|SER|CL|PP — código corto del criterio']
  nombre           varchar(100) [not null]
  descripcion      text    [not null, note: 'Descripción completa del criterio tal como aparece en la planilla CONSOLIDADO']
  es_requerido     boolean [default: true, note: 'Si no cumple, no se paga ese rubro de la liquidación']
  activo           boolean [default: true]
  created_at       timestamp [default: `now()`]

  Note: 'Criterios de acceso al pago por toneladas cargadas — fuente: PESO-EQUIPOS-GYH.xlsx hoja CONSOLIDADO. MP=Mant.Preventivo, RTE=Recoger Totalidad, SER=Sale con equipo y regresa con equipo+remisiones, CL=Entrega mismo día, PP=Presentación Personal. Si no cumple un criterio se descuenta esa remisión de la liquidación'
}

// Evaluación por conductor/viaje de criterios de liquidación
Table evaluacion_criterios_conductor {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  agenda_transporte_id uuid   [not null, ref: > agenda_transporte.id]
  conductor_id        uuid    [not null, ref: > conductores.id]
  criterio_id         uuid    [not null, ref: > config_criterios_liquidacion_conductor.id]
  cumplido            boolean [not null]
  observacion         text    [note: 'Justificación si no cumplió o nota del almacén']
  registrado_por      uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]

  indexes {
    (agenda_transporte_id, criterio_id) [unique]
    conductor_id
  }

  Note: 'Registro de cumplimiento de criterios por viaje — determina si el viaje califica para pago por tonelada'
}

// ============================================================
// MÓDULO: KARDEX DE CONSUMIBLES (materiales de bodega interna)
// Separado del kardex_movimientos que es para equipos de alquiler
// Fuente: KARDEX.xlsx — hojas: PINTURA, DISOLVENTE, SOLDADURA 6013, SOLDADURA MIG, TORNILLOS, CONSUMIBLES
// ============================================================

Table consumibles_catalogo {
  id               uuid    [pk, default: `gen_random_uuid()`]
  codigo           varchar(100) [unique, not null]
  nombre           varchar(300) [not null, note: 'Ej: PINTURA ANTICORROSIVO, DISOLVENTE/THINNER, SOLDADURA REVESTIDA 6013, SOLDADURA MIG 0.35']
  categoria        varchar(100) [note: 'pintura|disolvente|soldadura|tornillos|gases|lubricantes|otro']
  unidad_medida    varchar(50)  [not null, note: 'CANECAS|BOLSA|CAJAS|LITROS|UNIDADES — según categoría']
  marca_referencia varchar(200)
  ubicacion_bodega varchar(100) [note: 'Ej: BODEGA 1 — del campo Ubicación en el KARDEX.xlsx']
  stock_minimo     integer      [note: 'Stock Mínimo del KARDEX.xlsx — alerta cuando se llega a este nivel']
  stock_maximo     integer      [note: 'Stock Máximo del KARDEX.xlsx']
  stock_actual     integer      [default: 0, note: 'Calculado automáticamente desde los movimientos']
  activo           boolean      [default: true]
  created_at       timestamp    [default: `now()`]
  updated_at       timestamp    [default: `now()`]

  Note: 'Catálogo de materiales de uso interno en bodega — NO son equipos de alquiler. Fuente: KARDEX.xlsx (G&H). Categorías reales: PINTURA ANTICORROSIVO (canecas), DISOLVENTE/THINNER (canecas), SOLDADURA REVESTIDA 6013 (bolsas), SOLDADURA MIG 0.35 (cajas), TORNILLOS (varias medidas), CONSUMIBLES (mezcla soldadura, gas montacargas, etc.)'
}

Table kardex_consumibles {
  id                  bigserial    [pk]
  consumible_id       uuid    [not null, ref: > consumibles_catalogo.id]
  fecha               date    [not null]
  numero_documento    varchar(100) [note: 'Número de documento fuente del movimiento (orden de compra, remisión interna, etc.)']
  tipo_movimiento     varchar(30)  [not null, note: 'entrada|salida|ajuste|inicio_sistema']
  cantidad_entrada    integer      [default: 0, note: 'Columna Entrada (Cantidad) del KARDEX.xlsx']
  cantidad_salida     integer      [default: 0, note: 'Columna Salida (Cantidad) del KARDEX.xlsx']
  saldo              integer      [not null, note: 'Saldo actualizado — columna Saldo (Cantidad) del KARDEX.xlsx']
  observaciones       text         [note: 'Columna Observaciones del KARDEX.xlsx']
  registrado_por      uuid    [ref: > usuarios.id]
  created_at          timestamp    [default: `now()`]

  indexes {
    consumible_id
    fecha
    (consumible_id, fecha)
  }

  Note: 'Kardex de movimientos de materiales de bodega — equivale digital al KARDEX.xlsx (G&H). Columnas: Fecha, Documento, Tipo de Movimiento, Entrada (Cantidad), Salida (Cantidad), Saldo (Cantidad), Observaciones'
}

// ============================================================
// MÓDULO: COTIZACIONES
// ============================================================

Table cotizaciones {
  id                   uuid         [pk, default: `gen_random_uuid()`]
  numero_cotizacion    varchar(50)  [unique, not null]
  cliente_id           uuid         [not null, ref: > clientes.id]
  obra_id              uuid         [ref: > obras.id]
  dibujante_id         uuid         [ref: > usuarios.id]
  comercial_id         uuid         [ref: > usuarios.id]
  estado               estado_cotizacion [default: 'borrador']

  // Tipos de negocio habilitados
  incluye_venta        boolean      [default: false]
  incluye_alquiler     boolean      [default: false]
  incluye_transporte   boolean      [default: false]
  incluye_reposicion   boolean      [default: false]

  // Totales calculados
  subtotal             decimal(18,2) [default: 0]
  descuento            decimal(18,2) [default: 0]
  iva                  decimal(18,2) [default: 0]
  total                decimal(18,2) [default: 0]

  // Archivos del proceso (AutoCAD → Excel → PDF)
  archivo_plano_url    varchar(500)
  archivo_excel_url    varchar(500)  [note: 'Desglose de materiales exportado desde AutoCAD']
  pdf_cotizacion_url   varchar(500)  [note: 'PDF final con valores comerciales agregados']

  // Indicador de catálogo especial
  usa_precios_especiales boolean     [default: false, note: 'true si el cliente tiene catalogo_precios_cliente vigente']

  notas_dibujante      text
  notas_comercial      text
  horas_modelamiento   decimal(4,2)  [note: 'Métrica: actualmente 4-6 horas en AutoCAD']
  codigo_revision      varchar(50)
  created_at           timestamp     [default: `now()`]
  updated_at           timestamp     [default: `now()`]

  indexes {
    cliente_id
    estado
    dibujante_id
    created_at
  }

  Note: 'Cotizaciones: 6-12 por semana por dibujante. Soporta venta, alquiler, transporte y reposición'
}

Table cotizacion_items {
  id                   uuid          [pk, default: `gen_random_uuid()`]
  cotizacion_id        uuid          [not null, ref: > cotizaciones.id]
  frente_id            uuid          [ref: > frentes_obra.id]
  producto_id          uuid          [not null, ref: > catalogo_productos.id]
  tipo_item            tipo_item_cotizacion [not null]
  cantidad             decimal(12,3) [default: 1]
  area_m2              decimal(12,2) [note: 'Para productos que calculan por metro cuadrado']
  precio_unitario      decimal(15,2) [not null]
  precio_por_m2        decimal(15,2)
  dias_alquiler        integer       [note: 'Para ítems de alquiler: desde pedido completo hasta devolución']
  // Transporte: peso Y volumen (SEM-27)
  proveedor_transporte proveedor_transporte [note: 'G&H provee y cobra el flete, o el cliente lo gestiona por su cuenta']
  peso_kg              decimal(10,2) [note: 'Peso del envío en kg — para cálculo de transporte']
  volumen_m3           decimal(10,2) [note: 'Volumen del envío en m³ — si llena el camión se cobra la tarifa completa']
  subtotal             decimal(18,2) [not null]
  descripcion_adicional text

  Note: 'Líneas de cotización. Transporte: G&H cobra por peso Y volumen (el mayor); si el cliente provee transporte, no se cobra flete'
}

Table archivos_planos {
  id             uuid    [pk, default: `gen_random_uuid()`]
  cotizacion_id  uuid    [not null, ref: > cotizaciones.id]
  nombre_archivo varchar(300) [not null]
  formato        formato_archivo [not null]
  url_archivo    varchar(500)   [not null]
  tipo_archivo   tipo_archivo_plano [not null]
  uploaded_by    uuid    [ref: > usuarios.id]
  created_at     timestamp [default: `now()`]

  Note: 'Planos AutoCAD (DWG/DXF), exports Excel y PDFs de cotización'
}

// ============================================================
// MÓDULO: CONTRATOS Y ÓRDENES DE COMPRA
// ============================================================

Table ordenes_compra {
  id                    uuid    [pk, default: `gen_random_uuid()`]
  numero_orden          varchar(50) [unique, not null]
  cotizacion_id         uuid    [not null, ref: > cotizaciones.id]
  cliente_id            uuid    [not null, ref: > clientes.id]
  obra_id               uuid    [ref: > obras.id]
  estado                estado_orden [default: 'pendiente']
  fecha_inicio          date
  fecha_estimada_fin    date
  fecha_fin_real        date
  notas                 text
  created_at            timestamp [default: `now()`]
  updated_at            timestamp [default: `now()`]

  Note: 'Orden de compra generada una vez el cliente aprueba la cotización'
}

Table contratos {
  id                      uuid    [pk, default: `gen_random_uuid()`]
  numero_contrato         varchar(50) [unique, not null]
  orden_compra_id         uuid    [unique, not null, ref: > ordenes_compra.id]
  cliente_id              uuid    [not null, ref: > clientes.id]
  estado                  estado_contrato [default: 'borrador']

  // Integración con firma electrónica (DocuSign / Okc)
  plataforma_firma        varchar(100) [note: 'DocuSign, Okc u otra plataforma']
  id_documento_externo    varchar(200) [note: 'ID del documento en la plataforma de firma']
  url_documento_firmado   varchar(500)
  fecha_envio_firma       timestamp
  fecha_firma             timestamp
  firmado_por             varchar(200)

  created_at              timestamp [default: `now()`]
  updated_at              timestamp [default: `now()`]

  Note: 'Contratos con integración a firma electrónica — trigger automático a operaciones al firmarse'
}

// ============================================================
// MÓDULO: INVENTARIOS Y LOGÍSTICA
// ============================================================

// Pedidos de despacho (SEM-27)
Table pedidos {
  id                     uuid    [pk, default: `gen_random_uuid()`]
  numero_pedido          varchar(50) [unique, not null]
  orden_compra_id        uuid    [not null, ref: > ordenes_compra.id]
  cliente_id             uuid    [not null, ref: > clientes.id, note: 'Desnormalizado de orden_compra — permite consulta directa cliente→obra→frente']
  obra_id                uuid    [not null, ref: > obras.id]
  frente_id              uuid    [ref: > frentes_obra.id]
  estado                 estado_pedido [default: 'pendiente']
  fecha_pedido           date    [not null]
  fecha_entrega_estimada date
  autorizado_por         uuid    [ref: > usuarios.id, note: 'Ingeniero o Comercial que autoriza el despacho']
  fecha_autorizacion     timestamp
  motivo_cancelacion     text
  cancelado_por          uuid    [ref: > usuarios.id]
  fecha_alquiler_inicio  date    [note: 'Establecida automáticamente cuando estado = completo — desde aquí corren los días de alquiler']
  notas                  text
  created_at             timestamp [default: `now()`]
  updated_at             timestamp [default: `now()`]

  indexes {
    orden_compra_id
    cliente_id
    obra_id
    estado
    fecha_pedido
  }

  Note: 'Un pedido puede enviarse en múltiples viajes parciales. El alquiler SOLO inicia cuando el pedido queda completo'
}

Table pedido_items {
  id                uuid    [pk, default: `gen_random_uuid()`]
  pedido_id         uuid    [not null, ref: > pedidos.id]
  producto_id       uuid    [not null, ref: > catalogo_productos.id]
  cantidad_pedida   integer [not null]
  cantidad_enviada  integer [default: 0, note: 'Acumulado de remisiones de salida vinculadas a este pedido']
  created_at        timestamp [default: `now()`]

  Note: 'Ítems de un pedido — cantidad_enviada se actualiza con cada remisión parcial hasta igualar cantidad_pedida'
}

Table vehiculos {
  id                   uuid    [pk, default: `gen_random_uuid()`]
  placa                varchar(20)  [unique, not null, note: 'Placa del vehículo — ej: WHA 514, XGC 078']
  marca                varchar(100)
  modelo               varchar(100)
  tipo                 varchar(50)  [note: 'camion|furgon|camioneta|volqueta|otro']

  // Dimensiones del compartimento de carga (requeridas para cálculo de flete por volumen)
  largo_m              decimal(6,2) [note: 'Largo interior de carga en metros']
  ancho_m              decimal(6,2) [note: 'Ancho interior de carga en metros']
  alto_m               decimal(6,2) [note: 'Alto interior de carga en metros']

  // Capacidades de carga (usadas en reglas de liquidación del conductor)
  capacidad_peso_ton   decimal(6,3) [not null, note: 'Capacidad máxima en toneladas — para regla de combustible']
  capacidad_volumen_m3 decimal(8,3) [note: 'Capacidad volumétrica en m³ — si llena el camión se cobra tarifa completa']

  activo               boolean  [default: true]
  en_mantenimiento     boolean  [default: false]
  notas                text
  created_at           timestamp [default: `now()`]
  updated_at           timestamp [default: `now()`]

  indexes {
    placa
  }

  Note: 'Vehículos de la flota G&H — dimensiones y capacidades para cálculo de flete (peso Y volumen, el mayor)'
}

Table conductores {
  id           uuid    [pk, default: `gen_random_uuid()`]
  nombre       varchar(200) [not null]
  cedula       varchar(50)  [unique, not null]
  telefono     varchar(50)
  celular      varchar(50)
  vehiculo_id  uuid    [ref: > vehiculos.id, note: 'Vehículo principal asignado — puede cambiar']
  // Campos rápidos de placa y tipo para formularios de despacho (confirmados en fotos)
  placa        varchar(20)  [note: 'Copia de vehiculos.placa para acceso rápido en remisiones']
  tipo_vehiculo varchar(100) [note: 'Descripción corta del vehículo']
  activo       boolean  [default: true]
  created_at   timestamp [default: `now()`]
  updated_at   timestamp [default: `now()`]

  Note: 'Conductores para transporte de equipos a obras — Jose/WHA514, Mario/XGC078, Jiffer/PKG947, Oscar/FCF086, Fernando/BPU45H, Wilson/AFE575'
}

Table conductor_vehiculos {
  id           uuid    [pk, default: `gen_random_uuid()`]
  conductor_id uuid    [not null, ref: > conductores.id]
  vehiculo_id  uuid    [not null, ref: > vehiculos.id]
  fecha_desde  date    [not null]
  fecha_hasta  date
  es_principal boolean [default: true, note: 'Vehículo principal asignado al conductor en este período']

  indexes {
    (conductor_id, vehiculo_id, fecha_desde) [unique]
    conductor_id
    vehiculo_id
  }

  Note: 'Historial de asignación conductor→vehículo — permite saber qué placa usó cada conductor en cada fecha'
}

Table remisiones {
  id               uuid    [pk, default: `gen_random_uuid()`]
  numero_remision  varchar(50) [unique, not null, note: 'Ej: FM REMISION #01064 — prefijo por línea de negocio']
  orden_compra_id  uuid    [not null, ref: > ordenes_compra.id]
  pedido_id        uuid    [ref: > pedidos.id, note: 'Pedido al que pertenece esta remisión (puede ser parcial)']
  // Relación directa cliente→obra→frente (desnormalizada para consulta eficiente)
  cliente_id       uuid    [not null, ref: > clientes.id]
  obra_id          uuid    [not null, ref: > obras.id]
  frente_id        uuid    [ref: > frentes_obra.id]
  frente_ajuste_id uuid    [ref: > frentes_obra.id, note: 'Frente al que se reasignó cuando hay préstamo entre frentes']
  tipo_remision    tipo_remision [not null]
  es_parcial       boolean [default: false, note: 'true si el pedido asociado no está aún completo']
  fecha_remision   date    [not null]
  hora_remision    time    [note: 'Hora exacta del despacho o recepción']
  responsable_id   uuid    [ref: > usuarios.id]
  conductor_id     uuid    [ref: > conductores.id]
  vehiculo_id      uuid    [ref: > vehiculos.id, note: 'Vehículo usado en este viaje — con dimensiones y capacidad']
  placa            varchar(20) [note: 'Placa del vehículo en el momento del despacho (confirmada en fotos)']
  direccion_recogida text
  direccion_destino  text
  // Transporte
  cobra_transporte   boolean [default: false, note: 'Se Cobra Transporte de Llevada S/N — campo Siigo ELABORACIÓN DE REMISIÓN']
  valor_transporte   decimal(15,2) [note: 'Valor cobrado al arrendatario por transporte']
  // Datos de obra y contacto (del formulario físico de despacho)
  contacto_obra      varchar(200) [note: 'Persona de contacto en la obra — campo CONTACTO del formato']
  asesor_id          uuid    [ref: > usuarios.id, note: 'Asesor comercial del despacho — campo ASESOR']
  fecha_entrega_obra date    [note: 'Fecha pactada de entrega en obra — campo FECHA DE ENTREGA']
  // Autorización de entrega y recibo (firma electrónica / nombre en el formato)
  autorizacion_entregar varchar(200) [note: 'Nombre/CC quien autoriza la entrega desde G&H']
  autorizacion_recibir  varchar(200) [note: 'Nombre/CC quien autoriza recibir en obra']
  firma_entrega_nombre  varchar(200) [note: 'QUIEN ENTREGA DESPACHO — nombre claro en el formato físico']
  firma_recibe_nombre   varchar(200) [note: 'QUIEN RECIBE CONDUCTOR — nombre claro en la obra']
  firma_recibe_cc       varchar(50)  [note: 'CC de quien recibe en la obra']
  // Descargue en bodega (FT-DE-002)
  hora_llegada_bodega   time  [note: 'Hora de llegada del conductor a bodega en devolución']
  hora_salida_bodega    time  [note: 'Hora de salida de bodega']
  ayudante_nombre       varchar(200) [note: 'Nombre del ayudante en el descargue — firma en formato FT-DE-002']
  // Verificación 3 fuentes en devolución (SEM-27)
  formato_conductor    text   [note: 'Registro del conductor: lo que dice haber traído']
  formato_despachador  text   [note: 'Conteo físico del despachador en bodega']
  fotos_porteria_urls  text[] [note: 'URLs de fotos de portería de la obra — evidencia salida (S3)']
  cruce_ajuste         text   [note: 'Justificación cuando se reasigna a otro frente por equipo prestado entre frentes']
  pdf_remision_url     varchar(500) [note: 'URL del PDF de la remisión generada (S3)']
  observaciones        text
  estado               estado_remision [default: 'programada']
  created_at           timestamp [default: `now()`]
  updated_at           timestamp [default: `now()`]

  indexes {
    orden_compra_id
    pedido_id
    cliente_id
    obra_id
    tipo_remision
    fecha_remision
    conductor_id
  }

  Note: 'Remisiones de salida y entrada al Kardex — incluye verificación de 3 fuentes en devoluciones. Formato físico tiene: No., Fecha, Constructora, Obra, Frente, Asesor, Contacto, LARGO/ANCHO/ALTO/CANTIDAD/ÁREA/PESO por ítem'
}

Table remision_items {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  remision_id         uuid    [not null, ref: > remisiones.id]
  producto_id         uuid    [not null, ref: > catalogo_productos.id]
  cantidad_programada integer [not null]
  cantidad_real       integer
  // Dimensiones físicas del ítem (columnas LARGO, ANCHO, ALTO del formato de despacho)
  largo_m             decimal(8,3) [note: 'Dimensión LARGO en metros — del formato físico de despacho']
  ancho_m             decimal(8,3) [note: 'Dimensión ANCHO en metros']
  alto_m              decimal(8,3) [note: 'Dimensión ALTO en metros']
  area_m2             decimal(10,3) [note: 'ÁREA calculada = largo × ancho — para formaletas']
  // Peso (columna PESO KG del formato de despacho)
  peso_kg_unitario    decimal(10,3) [note: 'Peso unitario del elemento en kg — columna PESO KG del despacho']
  peso_total_kg       decimal(12,3) [note: 'Peso total del ítem = cantidad × peso_kg_unitario']
  // Estado en devolución (BUENO/REGULAR/MALO del formato de devolución)
  condicion_devolucion condicion_equipo_devolucion [note: 'Estado físico al retornar a bodega: BUENO/REGULAR/MALO']
  estado_item         estado_item_remision [default: 'pendiente']
  novedad             text    [note: 'Descripción de daño, faltante, mantenimiento o equipo ajeno']
  clasificado_por     uuid    [ref: > usuarios.id, note: 'Conductor o Despachador que clasificó el estado']

  Note: 'Detalle de equipos por remisión. Formato físico tiene: LARGO, ANCHO, ALTO, CANTIDAD, ÁREA, PESO KG. En devolución: BUENO/REGULAR/MALO'
}

// Cronograma diario Recepción → Almacén (SEM-27)
Table cronograma_recogidas {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  fecha               date    [not null]
  cliente_id          uuid    [not null, ref: > clientes.id]
  obra_id             uuid    [not null, ref: > obras.id]
  frente_id           uuid    [ref: > frentes_obra.id, note: 'Frente específico de la recogida si aplica']
  numero_corte        varchar(50) [note: 'CT=XXXXX — número de contrato del cliente']
  fecha_corte         date
  estado              varchar(20) [default: 'programada', note: 'programada|parcial|completada|sin_recoger']
  registrado_por      uuid    [ref: > usuarios.id, note: 'Viviana — Recepción']
  notas               text
  created_at          timestamp [default: `now()`]
  updated_at          timestamp [default: `now()`]

  indexes {
    fecha
    estado
    obra_id
  }

  Note: 'Cronograma diario: Viviana (Recepción) lo crea; Almacén (Angie) actualiza con recogidas realizadas'
}

// Equipo ajeno recibido en devoluciones (SEM-27)
Table equipos_ajenos {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  remision_id         uuid    [ref: > remisiones.id]
  descripcion         text    [not null]
  empresa_origen      varchar(200) [note: 'Empresa a quien pertenece el equipo']
  fecha_recepcion     date    [not null]
  estado              varchar(20) [default: 'en_bodega', note: 'en_bodega|devuelto']
  fecha_devolucion    date
  devuelto_a          varchar(200)
  notas               text
  registrado_por      uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]

  Note: 'Equipo que no pertenece a G&H y llega en devoluciones — debe ser devuelto a la empresa correspondiente'
}

Table agenda_transporte {
  id                 uuid    [pk, default: `gen_random_uuid()`]
  remision_id        uuid    [not null, ref: > remisiones.id]
  conductor_id       uuid    [not null, ref: > conductores.id]
  vehiculo_id        uuid    [ref: > vehiculos.id]
  // Relación directa cliente→obra→frente
  cliente_id         uuid    [ref: > clientes.id]
  obra_id            uuid    [ref: > obras.id]
  frente_id          uuid    [ref: > frentes_obra.id]
  fecha_programada   date    [not null]
  hora_inicio        time
  hora_fin           time
  direccion_recogida text
  direccion_destino  text    [not null]
  orden_compra_id    uuid    [ref: > ordenes_compra.id]
  // Datos de trayecto para liquidación del conductor
  km_trayecto        decimal(8,2) [note: 'Distancia calculada entre recogida y entrega en km (Maps API)']
  peso_cargado_ton   decimal(8,3) [note: 'Peso real cargado en toneladas — para regla de combustible']
  volumen_cargado_m3 decimal(8,3) [note: 'Volumen real ocupado en m³ — para cálculo de flete']
  valor_liquidacion  decimal(15,2) [note: 'Valor a pagar al conductor = f(km, toneladas, volumen, combustible)']
  estado_agenda      estado_agenda [default: 'programado']
  notas              text
  created_at         timestamp [default: `now()`]
  updated_at         timestamp [default: `now()`]

  indexes {
    conductor_id
    fecha_programada
    cliente_id
    obra_id
  }

  Note: 'Agenda del jefe de almacén: conductores, horarios, direcciones y cálculo de liquidación por trayecto'
}

// ============================================================
// MÓDULO: FACTURACIÓN Y CARTERA
// ============================================================

Table facturas {
  id               uuid    [pk, default: `gen_random_uuid()`]
  numero_factura   varchar(50)  [unique, not null]
  orden_compra_id  uuid    [not null, ref: > ordenes_compra.id]
  cliente_id       uuid    [not null, ref: > clientes.id]
  estado           estado_factura [default: 'pendiente']
  fecha_emision    date    [not null]
  fecha_vencimiento date   [not null]

  // Modalidad y centro de costo (SEM-27)
  modalidad_factura modalidad_factura [note: 'Por remisión, consolidada o por valor — transporte siempre va en factura separada']
  centro_costo      varchar(5)        [note: '13=alquiler · 14=venta_reposicion — aplicado automáticamente según líneas']

  // Valores con retenciones (según condiciones FT-AC-001 Sección VI)
  subtotal         decimal(18,2) [not null]
  descuento        decimal(18,2) [default: 0]
  iva              decimal(18,2) [default: 0]
  rte_fuente       decimal(18,2) [default: 0]
  rte_ica          decimal(18,2) [default: 0]
  total            decimal(18,2) [not null]
  saldo_pendiente  decimal(18,2) [not null]

  // Validación DIAN (SEM-27)
  // Integración Siigo → DIAN (no es directa — flujo: factura → Siigo → DIAN)
  cufe             varchar(200)  [note: 'Código Único de Factura Electrónica — generado por Siigo al transmitir a DIAN']
  siigo_estado     varchar(30)   [note: 'Estado en Siigo: sin_enviar|enviada_siigo|rechazada_siigo|transmitida_dian']
  siigo_enviada_at timestamp     [note: 'Fecha y hora en que se envió a Siigo']
  estado_radian    estado_radian [default: 'sin_enviar', note: 'Estado validado por Facturación en portal DIAN — fuente de verdad (no el estado de Siigo)']
  fecha_envio_dian timestamp     [note: 'Fecha de transmisión oficial a la DIAN (vía Siigo)']
  fecha_validacion_dian timestamp [note: 'Fecha en que Facturación confirmó el estado en portal DIAN']
  seguimiento_telefónico text    [note: 'Notas del seguimiento telefónico al cliente para confirmar recepción y procesamiento']

  // Fechas diferenciadas (visibles en la factura electrónica impresa)
  fecha_elaboracion    timestamp [note: 'Fecha de elaboración de la factura — campo visible en PDF']
  fecha_expedicion     timestamp [note: 'Fecha de expedición oficial — puede diferir de elaboración']
  elaborado_por        uuid    [ref: > usuarios.id, note: 'Usuario que generó la factura']
  pdf_url              varchar(500) [note: 'URL del PDF de la factura electrónica (S3)']
  notas                text
  created_at           timestamp [default: `now()`]
  updated_at           timestamp [default: `now()`]

  indexes {
    cliente_id
    estado
    fecha_vencimiento
    numero_factura
  }

  Note: 'Facturación electrónica — CUFE + Radian son la prueba oficial (no el estado en Siigo). Factura BTA muestra: elaboración, expedición, vencimiento, sucursal, dir. obra'
}

Table factura_items {
  id                 uuid    [pk, default: `gen_random_uuid()`]
  factura_id         uuid    [not null, ref: > facturas.id]
  cotizacion_item_id uuid    [ref: > cotizacion_items.id]
  descripcion        text    [not null]
  tipo_cobro         tipo_item_cotizacion [not null]
  cantidad           decimal(12,3) [default: 1]
  area_m2            decimal(12,2)
  dias_alquiler      integer [note: 'Calculado desde fecha pedido completo hasta devolución']
  precio_unitario    decimal(15,2) [not null]
  subtotal           decimal(18,2) [not null]
  // Retenciones por tipo de concepto (SEM-27)
  centro_costo       varchar(5)   [note: '13=alquiler · 14=venta_reposicion (automático por tipo_cobro)']
  retencion_tipo     varchar(30)  [note: 'rte_fuente|rte_ica|iva — diferente según tipo: transporte ≠ alquiler']
  retencion_porcentaje decimal(5,2) [note: 'Porcentaje aplicado automáticamente desde retenciones_config']

  Note: 'Líneas de factura con retención automática por tipo de concepto — no mezclar alquiler y transporte'
}

Table pagos {
  id              uuid    [pk, default: `gen_random_uuid()`]
  factura_id      uuid    [not null, ref: > facturas.id]
  monto           decimal(18,2) [not null]
  fecha_pago      date    [not null]
  hora_pago       time    [note: 'Hora del pago para trazabilidad completa']
  metodo_pago     metodo_pago [not null]
  referencia_pago varchar(200)
  registrado_por  uuid    [ref: > usuarios.id]
  notas           text
  created_at      timestamp [default: `now()`]

  Note: 'Registro de pagos — gestionado por Cartera (Facturación solo genera y valida envío a DIAN)'
}

Table cartera {
  id                   uuid    [pk, default: `gen_random_uuid()`]
  factura_id           uuid    [unique, not null, ref: > facturas.id]
  cliente_id           uuid    [not null, ref: > clientes.id]
  dias_mora            integer [default: 0]
  monto_mora           decimal(18,2) [default: 0]
  estado_gestion       estado_cartera [default: 'nueva']
  fecha_ultimo_contacto date
  tipo_contacto_cobro  varchar(20) [note: 'llamada_telefonica|email|visita — según tipo_dominio_correo del cliente']
  cufe_evidencia       varchar(200) [note: 'CUFE para mostrar al cliente que alega no haber recibido la factura']
  notas_gestion        text
  responsable_id       uuid    [ref: > usuarios.id]
  created_at           timestamp [default: `now()`]
  updated_at           timestamp [default: `now()`]

  Note: 'Gestión de cartera — Cartera es quien hace el seguimiento de pagos; Facturación solo valida envío a DIAN'
}

// ============================================================
// MÓDULO: KARDEX DE MOVIMIENTOS (Inventario transaccional)
// ============================================================

Table kardex_movimientos {
  id                  bigserial    [pk]
  producto_id         uuid    [not null, ref: > catalogo_productos.id]
  // Relación completa cliente→obra→frente (permite Listado de Kardex de Clientes por NIT)
  cliente_id          uuid    [ref: > clientes.id, note: 'NULL = movimiento interno (ajuste, baja, inicio de sistema)']
  obra_id             uuid    [ref: > obras.id]
  frente_id           uuid    [ref: > frentes_obra.id]
  remision_id         uuid    [ref: > remisiones.id, note: 'Remisión que originó el movimiento']
  pedido_id           uuid    [ref: > pedidos.id]

  tipo_movimiento     varchar(30) [not null, note: 'salida|entrada_devolucion|entrada_reposicion|ajuste|baja|mantenimiento|inicio_sistema']

  // Cantidades (replica columnas del Listado Kardex Clientes de Siigo: CAN.ENV, CAN.DEV)
  cantidad_enviada    integer  [default: 0, note: 'Unidades despachadas a obra — columna CAN.ENV']
  cantidad_devuelta   integer  [default: 0, note: 'Unidades retornadas a bodega — columna CAN.DEV']
  cantidad_ajuste     integer  [default: 0, note: 'Ajuste manual de inventario (positivo o negativo)']
  saldo               integer  [not null, note: 'Saldo en bodega después del movimiento — puede ser negativo al inicio']

  // Referencia al documento fuente (columnas No.ENVIO, No.DEVOL. del Kardex Siigo)
  numero_envio        varchar(50) [note: 'Número de remisión de salida — No.ENVIO en Siigo']
  numero_devolucion   varchar(50) [note: 'Número de remisión de entrada — No.DEVOL. en Siigo']
  numero_documento    varchar(50) [note: 'Número genérico del documento fuente']

  fecha               date    [not null]
  registrado_por      uuid    [ref: > usuarios.id]
  observaciones       text
  created_at          timestamp [default: `now()`]

  indexes {
    producto_id
    (cliente_id, producto_id)
    cliente_id
    obra_id
    fecha
    (producto_id, fecha)
    remision_id
  }

  Note: 'Kardex transaccional de movimientos por producto — base para el reporte Listado de Kardex de Clientes (equivalente al informe Siigo: NIT+Producto, ENE→JUN, CAN.ENV/CAN.DEV/SALDO)'
}

// ============================================================
// MÓDULO: REPORTERÍA
// (Tablas de agregados pre-calculados para informes del sistema)
// ============================================================

// 1. Kardex de clientes por período (equivalente al Listado de Kardex de Clientes de Siigo)
Table rpt_kardex_cliente {
  id                  bigserial    [pk]
  cliente_id          uuid    [not null, ref: > clientes.id]
  producto_id         uuid    [not null, ref: > catalogo_productos.id]
  obra_id             uuid    [ref: > obras.id]
  periodo_inicio      date    [not null]
  periodo_fin         date    [not null]
  num_envios          integer  [default: 0, note: 'Número de remisiones de salida en el período']
  num_devoluciones    integer  [default: 0, note: 'Número de remisiones de entrada en el período']
  cant_enviada_total  integer  [default: 0, note: 'CAN.ENV — total unidades enviadas']
  cant_devuelta_total integer  [default: 0, note: 'CAN.DEV — total unidades devueltas']
  saldo_pendiente     integer  [default: 0, note: 'Unidades aún en obra (enviadas - devueltas)']
  generado_at         timestamp [default: `now()`]
  generado_por        uuid    [ref: > usuarios.id]

  indexes {
    (cliente_id, producto_id, periodo_inicio, periodo_fin) [unique]
    cliente_id
    periodo_inicio
  }

  Note: 'Reporte Kardex de Clientes — equivalente al Listado de Kardex de Siigo agrupado por NIT+Producto en un período (ENE→JUN)'
}

// 2. Estado de pedidos (equivalente al Excel de seguimiento con COMPLETO/PARCIAL)
Table rpt_estado_pedidos {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  pedido_id           uuid    [unique, not null, ref: > pedidos.id]
  cliente_id          uuid    [not null, ref: > clientes.id]
  obra_id             uuid    [not null, ref: > obras.id]
  numero_pedido       varchar(50) [not null]
  numero_contrato     varchar(50) [note: 'CT=XXXXX — número visible en pizarrón y Excel de seguimiento']
  estado              estado_pedido [not null]
  porcentaje_enviado  decimal(5,2) [default: 0, note: '% del pedido ya despachado']
  total_items         integer  [default: 0]
  items_enviados      integer  [default: 0]
  fecha_pedido        date
  fecha_estimada_fin  date
  fecha_completado    date
  observaciones       text
  actualizado_at      timestamp [default: `now()`]

  indexes {
    cliente_id
    estado
    fecha_pedido
    numero_contrato
  }

  Note: 'Reporte de estado de pedidos — equivalente al Excel de seguimiento con colores COMPLETO (verde) / PARCIAL (rojo)'
}

// 3. Facturación por período y cliente
Table rpt_facturacion_periodo {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  periodo_inicio      date    [not null]
  periodo_fin         date    [not null]
  cliente_id          uuid    [not null, ref: > clientes.id]
  sucursal            ciudad_sucursal
  total_facturas      integer  [default: 0]
  total_bruto         decimal(18,2) [default: 0]
  total_descuentos    decimal(18,2) [default: 0]
  total_iva           decimal(18,2) [default: 0]
  total_rte_fuente    decimal(18,2) [default: 0, note: 'RETEFUENTE — visible en factura electrónica']
  total_rte_ica       decimal(18,2) [default: 0]
  total_neto          decimal(18,2) [default: 0, note: 'Total a Pagar = bruto - retenciones']
  total_pagado        decimal(18,2) [default: 0]
  saldo_pendiente     decimal(18,2) [default: 0]
  generado_at         timestamp [default: `now()`]
  generado_por        uuid    [ref: > usuarios.id]

  indexes {
    (cliente_id, periodo_inicio, periodo_fin) [unique]
    periodo_inicio
    sucursal
  }

  Note: 'Reporte de facturación por período y cliente — incluye retenciones (RETEFUENTE/RteICA) y saldo pendiente'
}

// 4. Cartera vencida por tramos (aging report)
Table rpt_cartera_vencida {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  fecha_corte         date    [not null]
  cliente_id          uuid    [not null, ref: > clientes.id]
  sucursal            ciudad_sucursal
  // Tramos de mora (días de vencimiento)
  saldo_0_30          decimal(18,2) [default: 0, note: 'Facturas vencidas hace 0-30 días']
  saldo_31_60         decimal(18,2) [default: 0, note: '31-60 días de mora']
  saldo_61_90         decimal(18,2) [default: 0, note: '61-90 días de mora']
  saldo_91_180        decimal(18,2) [default: 0, note: '91-180 días de mora']
  saldo_mas_180       decimal(18,2) [default: 0, note: 'Más de 180 días — candidato a demanda jurídica']
  total_cartera       decimal(18,2) [default: 0]
  en_acuerdo_pago     boolean  [default: false]
  en_demanda          boolean  [default: false]
  generado_at         timestamp [default: `now()`]

  indexes {
    (cliente_id, fecha_corte) [unique]
    fecha_corte
  }

  Note: 'Reporte de cartera vencida por tramos de días (aging) — base para gestión de cobro y escalada a jurídico'
}

// 5. Liquidación de conductores por período
Table rpt_conductores_viajes {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  periodo_inicio      date    [not null]
  periodo_fin         date    [not null]
  conductor_id        uuid    [not null, ref: > conductores.id]
  vehiculo_id         uuid    [ref: > vehiculos.id]
  total_viajes        integer  [default: 0]
  km_total            decimal(12,2) [default: 0, note: 'km totales recorridos en el período']
  peso_total_ton      decimal(12,3) [default: 0, note: 'Toneladas transportadas en el período']
  volumen_total_m3    decimal(12,3) [default: 0, note: 'm³ ocupados en el período']
  valor_combustible   decimal(18,2) [default: 0, note: 'Costo estimado de combustible calculado por regla']
  valor_liquidacion   decimal(18,2) [default: 0, note: 'Total a pagar = f(km, toneladas, volumen, combustible, criterios) — regla configurable por SuperAdmin']
  // Resumen de criterios en el período
  viajes_con_mp       integer [default: 0, note: 'Viajes que cumplieron criterio MP (Mantenimiento Preventivo)']
  viajes_con_rte      integer [default: 0, note: 'Viajes que cumplieron criterio RTE (Recoger Totalidad)']
  viajes_con_ser      integer [default: 0, note: 'Viajes que cumplieron criterio SER (Sale y Regresa con equipo)']
  viajes_con_cl       integer [default: 0, note: 'Viajes que cumplieron criterio CL (Entrega mismo día)']
  viajes_con_pp       integer [default: 0, note: 'Viajes que cumplieron criterio PP (Presentación Personal)']
  viajes_calificados  integer [default: 0, note: 'Viajes que califican para pago por tonelada (cumplieron todos los criterios obligatorios)']
  generado_at         timestamp [default: `now()`]
  generado_por        uuid    [ref: > usuarios.id]

  indexes {
    (conductor_id, periodo_inicio, periodo_fin) [unique]
    periodo_inicio
    conductor_id
  }

  Note: 'Reporte de liquidación de conductores por período — incluye resumen de criterios MP/RTE/SER/CL/PP por viaje. Solo viajes_calificados se pagan a tarifa de tonelada. Fuente: evaluacion_criterios_conductor + config_tarifas_transporte'
}

// 6. Rotación de inventario por producto
Table rpt_inventario_rotacion {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  periodo_inicio      date    [not null]
  periodo_fin         date    [not null]
  producto_id         uuid    [not null, ref: > catalogo_productos.id]
  unidad_negocio      varchar(50) [note: 'formaleta_metalica|multidireccional|transporte|etc.']
  stock_inicial       integer  [default: 0]
  total_enviado       integer  [default: 0]
  total_devuelto      integer  [default: 0]
  stock_final         integer  [default: 0]
  stock_en_obra       integer  [default: 0, note: 'Unidades actualmente en clientes = enviadas - devueltas']
  dias_promedio_obra  decimal(6,1) [note: 'Promedio de días en obra por ciclo de alquiler']
  tasa_rotacion       decimal(6,2) [note: 'Veces que rotó el inventario en el período']
  generado_at         timestamp [default: `now()`]

  indexes {
    (producto_id, periodo_inicio, periodo_fin) [unique]
    unidad_negocio
    periodo_inicio
  }

  Note: 'Reporte de rotación de inventario por producto y línea de negocio — base para decisiones de compra y reposición'
}

// ============================================================
// GESTIÓN DE INVENTARIOS POR BODEGA (NUEVO - Julio 2026)
// ============================================================

// Tabla de distribución de inventario por bodega
Table bodegas_inventario {
  id                    uuid         [pk, default: `gen_random_uuid()`]
  producto_id           uuid         [not null, ref: > catalogo_productos.id]
  bodega_id             bodega_id    [not null]

  // Distribución de stock
  stock_disponible      integer      [default: 0, note: 'Unidades disponibles para alquiler en esta bodega']
  stock_en_alquiler     integer      [default: 0, note: 'Unidades actualmente alquiladas (solo aplica a bodega_50)']
  stock_mantenimiento   integer      [default: 0, note: 'Unidades en mantenimiento (principalmente bodega_40)']

  // Auditoría
  ultima_actualizacion  timestamp    [default: `now()`]
  actualizado_por       uuid         [ref: > usuarios.id]

  indexes {
    (producto_id, bodega_id) [unique, note: 'Un producto puede tener inventario en múltiples bodegas']
    bodega_id
    producto_id
  }

  Note: '''
    Sistema de inventarios consultivo (no restrictivo) por bodegas.

    4 BODEGAS:
    - Bodega 1 (Engativá): Principal — stock_disponible + stock_mantenimiento
    - Bodega 2 (Luz): Secundaria — stock_disponible + stock_mantenimiento
    - Bodega 40 (Mantenimiento): Solo stock_mantenimiento — equipo en reparación
    - Bodega 50 (Clientes): Solo stock_en_alquiler — equipo en poder de clientes

    VISIBILIDAD POR ROL:
    - Almacén/Despachador: Ve las 4 bodegas
    - Producción: Ve Bodega 1, 2 y 40 (NO ve Bodega 50)
    - Soporte Atención: Ve Bodega 1 y 2 (NO ve Bodega 40 ni 50)
    - Comercial: Consulta para cotizaciones

    FILOSOFÍA CONSULTIVA:
    - Sistema MUESTRA disponibilidad
    - Sistema ADVIERTE si stock bajo (< 50 unidades)
    - Sistema NO BLOQUEA operaciones
    - Permite crear cotizaciones y pedidos con stock insuficiente
    - Decisión final es del operador/comercial

    INDICADORES DE STOCK:
    - Sin stock: 0 unidades (🔴)
    - Stock bajo: < 50 unidades (🟡)
    - Stock medio: 50-200 unidades (🟢)
    - Stock alto: > 200 unidades (🔵)
  '''
}

// ============================================================
// DIMENSIONES DE TIEMPO (Para análisis temporal en BI)
// ============================================================

Table dim_fecha {
  fecha                date         [pk]
  anio                 integer      [not null]
  mes                  integer      [not null]
  mes_nombre           varchar(20)  [note: 'Enero, Febrero, ...']
  trimestre            integer      [not null]
  trimestre_nombre     varchar(10)  [note: 'Q1, Q2, Q3, Q4']
  semana               integer      [not null]
  dia_del_mes          integer      [not null]
  dia_de_la_semana     integer      [not null, note: '1=Lunes, 7=Domingo']
  dia_nombre           varchar(20)  [note: 'Lunes, Martes, ...']
  es_fin_de_semana     boolean      [default: false]
  es_festivo           boolean      [default: false]
  nombre_festivo       varchar(100)

  Note: '''
    Dimensión de tiempo para análisis temporal.
    Permite filtrar y agrupar por año, mes, trimestre, semana, día.
    Se genera una fila por cada fecha desde 2020-01-01 hasta 2030-12-31.
  '''
}

Table dim_hora {
  hora                 integer      [pk, note: '0-23']
  hora_12h             varchar(10)  [note: '12 AM - 11 PM']
  periodo_dia          varchar(20)  [note: 'Madrugada|Mañana|Tarde|Noche']
  turno_trabajo        varchar(20)  [note: 'Diurno|Nocturno']

  Note: '''
    Dimensión de hora para análisis de patrones horarios.
    Útil para analizar:
    - Horas pico de despachos
    - Tiempos de llegada de conductores
    - Patrones de facturación
  '''
}

// ============================================================
// TABLAS DE HECHOS (FACT TABLES) — Para análisis y BI
// ============================================================

Table fact_cotizaciones {
  id                  bigserial    [pk]
  fecha_cotizacion    date         [not null]
  anio                integer      [not null]
  mes                 integer      [not null]
  trimestre           integer      [not null]
  semana              integer      [not null]

  cotizacion_id       uuid         [not null, ref: > cotizaciones.id]
  cliente_id          uuid         [not null, ref: > clientes.id]
  obra_id             uuid         [ref: > obras.id]
  dibujante_id        uuid         [ref: > usuarios.id]
  comercial_id        uuid         [ref: > usuarios.id]
  ciudad_sucursal     ciudad_sucursal

  estado              estado_cotizacion [not null]
  incluye_venta       boolean      [default: false]
  incluye_alquiler    boolean      [default: false]
  incluye_transporte  boolean      [default: false]

  subtotal            decimal(18,2) [default: 0]
  descuento           decimal(18,2) [default: 0]
  iva                 decimal(18,2) [default: 0]
  total               decimal(18,2) [default: 0]

  horas_modelamiento  decimal(4,2)
  dias_hasta_respuesta integer     [note: 'Días desde creación hasta aprobación/rechazo']
  tasa_conversion     decimal(5,2) [note: '% de conversión a orden de compra']

  created_at          timestamp    [default: `now()`]
  updated_at          timestamp    [default: `now()`]

  indexes {
    (cliente_id, fecha_cotizacion)
    (comercial_id, fecha_cotizacion)
    (dibujante_id, fecha_cotizacion)
    (anio, mes)
    estado
  }

  Note: '''
    Tabla de hechos para análisis de cotizaciones.

    KPIs derivados:
    - Volumen de cotizaciones por período
    - Tasa de conversión cotización→orden
    - Tiempo promedio de respuesta
    - Valor promedio de cotización
    - Distribución por tipo de negocio
    - Productividad por dibujante (cotizaciones/semana)
  '''
}

Table fact_pedidos {
  id                     bigserial    [pk]
  fecha_pedido           date         [not null]
  anio                   integer      [not null]
  mes                    integer      [not null]
  trimestre              integer      [not null]

  pedido_id              uuid         [not null, ref: > pedidos.id]
  orden_compra_id        uuid         [not null, ref: > ordenes_compra.id]
  cliente_id             uuid         [not null, ref: > clientes.id]
  obra_id                uuid         [not null, ref: > obras.id]
  frente_id              uuid         [ref: > frentes_obra.id]
  ciudad_sucursal        ciudad_sucursal

  estado                 estado_pedido [not null]
  es_parcial             boolean      [default: false]
  dias_hasta_completo    integer      [note: 'Días desde pedido hasta estado = completo']
  dias_en_obra           integer      [note: 'Días desde pedido completo hasta devolución total']

  total_items            integer      [default: 0]
  items_despachados      integer      [default: 0]
  items_devueltos        integer      [default: 0]
  items_pendientes       integer      [default: 0]

  valor_estimado_alquiler decimal(18,2) [note: 'Valor estimado del alquiler (días × tarifa)']
  valor_real_facturado    decimal(18,2) [note: 'Valor real facturado al cliente']

  tiene_novedades        boolean      [default: false]
  tiene_faltantes        boolean      [default: false]
  tiene_danos            boolean      [default: false]

  created_at             timestamp    [default: `now()`]
  updated_at             timestamp    [default: `now()`]

  indexes {
    (cliente_id, fecha_pedido)
    (obra_id, fecha_pedido)
    (anio, mes)
    estado
  }

  Note: '''
    Tabla de hechos para análisis de pedidos.

    KPIs derivados:
    - Pedidos completos vs parciales
    - Tiempo promedio hasta despacho completo
    - Días promedio de alquiler por pedido
    - Valor promedio por pedido
    - Tasa de novedades (daños, faltantes)
    - Rotación de equipos
  '''
}

Table fact_remisiones {
  id                     bigserial    [pk]
  fecha_remision         date         [not null]
  anio                   integer      [not null]
  mes                    integer      [not null]
  trimestre              integer      [not null]

  remision_id            uuid         [not null, ref: > remisiones.id]
  tipo_remision          tipo_remision [not null]
  pedido_id              uuid         [ref: > pedidos.id]
  cliente_id             uuid         [not null, ref: > clientes.id]
  obra_id                uuid         [not null, ref: > obras.id]
  conductor_id           uuid         [ref: > conductores.id]
  vehiculo_id            uuid         [ref: > vehiculos.id]

  total_items            integer      [default: 0]
  peso_total_kg          decimal(12,3) [default: 0]
  volumen_total_m3       decimal(10,3) [default: 0]

  cobra_transporte       boolean      [default: false]
  valor_transporte       decimal(15,2)
  zona_transporte        varchar(50)  [note: 'bogota|fuera_bogota|ibague|armenia']

  tiene_novedades        boolean      [default: false]
  tiene_equipos_ajenos   boolean      [default: false]

  dias_desde_salida      integer      [note: 'Solo para tipo = entrada_devolucion']

  created_at             timestamp    [default: `now()`]
  updated_at             timestamp    [default: `now()`]

  indexes {
    (cliente_id, fecha_remision)
    (conductor_id, fecha_remision)
    (anio, mes)
    tipo_remision
  }

  Note: '''
    Tabla de hechos para análisis de remisiones.

    KPIs derivados:
    - Volumen de despachos/devoluciones
    - Peso y volumen transportado
    - Valor de transporte facturado
    - Días promedio de ciclo (salida→devolución)
    - Tasa de novedades en devoluciones
    - Productividad por conductor
  '''
}

Table fact_facturacion {
  id                     bigserial    [pk]
  fecha_factura          date         [not null]
  anio                   integer      [not null]
  mes                    integer      [not null]
  trimestre              integer      [not null]

  factura_id             uuid         [not null, ref: > facturas.id]
  orden_compra_id        uuid         [not null, ref: > ordenes_compra.id]
  cliente_id             uuid         [not null, ref: > clientes.id]
  ciudad_sucursal        ciudad_sucursal

  modalidad_factura      modalidad_factura
  centro_costo           varchar(5)   [note: '13=alquiler, 14=venta/reposición']
  estado                 estado_factura
  estado_radian          estado_radian

  subtotal               decimal(18,2) [not null]
  descuento              decimal(18,2) [default: 0]
  iva                    decimal(18,2) [default: 0]
  rte_fuente             decimal(18,2) [default: 0]
  rte_ica                decimal(18,2) [default: 0]
  total                  decimal(18,2) [not null]
  saldo_pendiente        decimal(18,2) [not null]

  dias_hasta_vencimiento integer
  dias_mora              integer      [default: 0]

  tiene_dominio_corporativo boolean   [note: 'Del campo tipo_dominio_correo del cliente']
  requiere_seguimiento_telefonico boolean

  created_at             timestamp    [default: `now()`]
  updated_at             timestamp    [default: `now()`]

  indexes {
    (cliente_id, fecha_factura)
    (anio, mes)
    estado
    estado_radian
    centro_costo
  }

  Note: '''
    Tabla de hechos para análisis de facturación.

    KPIs derivados:
    - Facturación por período
    - Facturación por centro de costo
    - Tasa de aprobación DIAN
    - Valor promedio de factura
    - Días promedio hasta pago
    - Cartera vencida por tramos
    - Retenciones totales
  '''
}

Table fact_inventario_movimientos {
  id                     bigserial    [pk]
  fecha_movimiento       date         [not null]
  anio                   integer      [not null]
  mes                    integer      [not null]
  trimestre              integer      [not null]

  producto_id            uuid         [not null, ref: > catalogo_productos.id]
  bodega_id              bodega_id    [not null]
  tipo_producto          tipo_producto
  unidad_negocio         varchar(50)

  tipo_movimiento        varchar(30)  [not null, note: 'salida|entrada_devolucion|ajuste|baja|mantenimiento']

  cantidad_salida        integer      [default: 0]
  cantidad_entrada       integer      [default: 0]
  stock_inicial_dia      integer      [default: 0]
  stock_final_dia        integer      [default: 0]

  remision_id            uuid         [ref: > remisiones.id]
  cliente_id             uuid         [ref: > clientes.id]

  valor_unitario         decimal(15,2)
  valor_total_movimiento decimal(18,2)

  created_at             timestamp    [default: `now()`]

  indexes {
    (producto_id, fecha_movimiento)
    (bodega_id, fecha_movimiento)
    (anio, mes)
    tipo_movimiento
  }

  Note: '''
    Tabla de hechos para análisis de inventario.

    KPIs derivados:
    - Rotación de inventario por producto
    - Stock promedio por bodega
    - Días de inventario disponible
    - Valor de inventario
    - Tasa de merma/baja
    - Análisis de movimientos por tipo
  '''
}

Table fact_productividad_usuarios {
  id                     bigserial    [pk]
  fecha                  date         [not null]
  anio                   integer      [not null]
  mes                    integer      [not null]
  semana                 integer      [not null]

  usuario_id             uuid         [not null, ref: > usuarios.id]
  rol                    rol_usuario  [not null]

  // Métricas por rol (según aplique)
  cotizaciones_creadas   integer      [default: 0, note: 'Dibujante/Comercial']
  horas_modelamiento     decimal(6,2) [default: 0, note: 'Dibujante']
  clientes_registrados   integer      [default: 0, note: 'Comercial/Soporte Atención']
  clientes_aprobados     integer      [default: 0, note: 'Contabilidad/Jurídica/Comercial']
  remisiones_procesadas  integer      [default: 0, note: 'Almacén/Despachador']
  viajes_realizados      integer      [default: 0, note: 'Conductor']
  facturas_generadas     integer      [default: 0, note: 'Facturación']
  pagos_registrados      integer      [default: 0, note: 'Cartera']

  acciones_total         integer      [default: 0, note: 'Total de acciones en auditoria']

  created_at             timestamp    [default: `now()`]

  indexes {
    (usuario_id, fecha)
    (rol, fecha)
    (anio, mes)
  }

  Note: '''
    Tabla de hechos para análisis de productividad por usuario/rol.

    KPIs derivados:
    - Productividad individual por rol
    - Comparativa entre usuarios del mismo rol
    - Tendencias de productividad
    - Identificación de cuellos de botella
    - Planificación de recursos
  '''
}

Table fact_tiempos_ciclo {
  id                     bigserial    [pk]
  fecha_inicio           date         [not null]
  fecha_fin              date
  anio                   integer      [not null]
  mes                    integer      [not null]

  tipo_ciclo             varchar(50)  [not null, note: 'prospecto_a_cliente|cotizacion_a_orden|pedido_a_completo|alquiler_completo|factura_a_pago']

  cliente_id             uuid         [ref: > clientes.id]
  cotizacion_id          uuid         [ref: > cotizaciones.id]
  pedido_id              uuid         [ref: > pedidos.id]
  factura_id             uuid         [ref: > facturas.id]

  dias_ciclo             integer      [note: 'Duración total del ciclo en días']
  estado_final           varchar(50)  [note: 'Estado en el que terminó el ciclo']

  created_at             timestamp    [default: `now()`]

  indexes {
    tipo_ciclo
    (cliente_id, tipo_ciclo)
    (anio, mes)
  }

  Note: '''
    Tabla de hechos para análisis de tiempos de ciclo.

    Ciclos medidos:
    1. Prospecto → Cliente Aprobado
    2. Cotización → Orden de Compra
    3. Pedido → Pedido Completo
    4. Alquiler (Salida → Devolución Total)
    5. Factura → Pago Completo

    KPIs derivados:
    - Tiempo promedio por tipo de ciclo
    - Identificación de demoras
    - Optimización de procesos
    - Predicción de tiempos
  '''
}

Table fact_calidad_servicio {
  id                     bigserial    [pk]
  fecha                  date         [not null]
  anio                   integer      [not null]
  mes                    integer      [not null]

  tipo_evento            varchar(50)  [not null, note: 'pedido_incompleto|novedad_devolucion|factura_rechazada|cliente_insatisfecho']
  severidad              varchar(20)  [note: 'baja|media|alta|critica']

  cliente_id             uuid         [ref: > clientes.id]
  obra_id                uuid         [ref: > obras.id]
  pedido_id              uuid         [ref: > pedidos.id]
  remision_id            uuid         [ref: > remisiones.id]
  factura_id             uuid         [ref: > facturas.id]

  descripcion            text
  causa_raiz             text
  accion_correctiva      text

  resuelto               boolean      [default: false]
  dias_hasta_resolucion  integer

  created_at             timestamp    [default: `now()`]
  updated_at             timestamp    [default: `now()`]

  indexes {
    tipo_evento
    (cliente_id, fecha)
    severidad
    resuelto
  }

  Note: '''
    Tabla de hechos para análisis de calidad de servicio.

    KPIs derivados:
    - Tasa de incidencias por tipo
    - Tiempo promedio de resolución
    - Clientes con más incidencias
    - Tendencias de calidad
    - Efectividad de acciones correctivas
  '''
}

// ============================================================
// AGREGADOS ADICIONALES (Tablas pre-calculadas para dashboards)
// ============================================================

Table agg_cotizaciones_mes {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  anio                   integer      [not null]
  mes                    integer      [not null]
  ciudad_sucursal        ciudad_sucursal
  dibujante_id           uuid         [ref: > usuarios.id]
  comercial_id           uuid         [ref: > usuarios.id]

  total_cotizaciones     integer      [default: 0]
  cotizaciones_borrador  integer      [default: 0]
  cotizaciones_enviadas  integer      [default: 0]
  cotizaciones_aprobadas integer      [default: 0]
  cotizaciones_rechazadas integer     [default: 0]
  cotizaciones_vencidas  integer      [default: 0]

  tasa_aprobacion        decimal(5,2) [note: '% de cotizaciones aprobadas']
  tiempo_prom_respuesta  decimal(6,2) [note: 'Días promedio hasta respuesta']

  valor_total_cotizado   decimal(18,2) [default: 0]
  valor_total_aprobado   decimal(18,2) [default: 0]

  horas_modelamiento_total decimal(8,2) [default: 0]

  generado_at            timestamp    [default: `now()`]

  indexes {
    (anio, mes)
    ciudad_sucursal
    dibujante_id
    comercial_id
  }

  Note: 'Agregado mensual de cotizaciones por sucursal, dibujante y comercial'
}

Table agg_ventas_mes {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  anio                   integer      [not null]
  mes                    integer      [not null]
  ciudad_sucursal        ciudad_sucursal
  centro_costo           varchar(5)   [note: '13=alquiler, 14=venta/reposición']

  total_facturas         integer      [default: 0]
  subtotal               decimal(18,2) [default: 0]
  iva                    decimal(18,2) [default: 0]
  retenciones            decimal(18,2) [default: 0]
  total_facturado        decimal(18,2) [default: 0]
  total_cobrado          decimal(18,2) [default: 0]
  saldo_pendiente        decimal(18,2) [default: 0]

  clientes_activos       integer      [default: 0, note: 'Clientes que facturaron en el mes']
  ticket_promedio        decimal(18,2) [default: 0]

  generado_at            timestamp    [default: `now()`]

  indexes {
    (anio, mes)
    ciudad_sucursal
    centro_costo
  }

  Note: 'Agregado mensual de ventas y alquileres por sucursal y centro de costo'
}

Table agg_inventario_mes {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  anio                   integer      [not null]
  mes                    integer      [not null]
  bodega_id              bodega_id    [not null]
  tipo_producto          tipo_producto
  unidad_negocio         varchar(50)

  stock_inicial_mes      integer      [default: 0]
  stock_final_mes        integer      [default: 0]
  stock_promedio_mes     integer      [default: 0]

  total_salidas          integer      [default: 0]
  total_entradas         integer      [default: 0]
  total_bajas            integer      [default: 0]
  total_mantenimiento    integer      [default: 0]

  tasa_rotacion          decimal(6,2) [note: 'Veces que rotó en el mes']
  dias_inventario        decimal(6,2) [note: 'Días de inventario disponible']

  valor_inventario       decimal(18,2) [default: 0]

  generado_at            timestamp    [default: `now()`]

  indexes {
    (anio, mes)
    bodega_id
    tipo_producto
  }

  Note: 'Agregado mensual de inventarios por bodega y tipo de producto'
}

Table agg_productividad_equipo {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  anio                   integer      [not null]
  mes                    integer      [not null]

  area                   varchar(50)  [note: 'comercial|dibujante|almacen|facturacion|cartera']

  total_usuarios_activos integer      [default: 0]
  acciones_promedio      decimal(8,2) [default: 0]
  productividad_promedio decimal(8,2) [default: 0, note: 'Métrica específica por área']

  // Métricas específicas
  cotizaciones_por_dibujante decimal(6,2)
  clientes_por_comercial     decimal(6,2)
  remisiones_por_despachador decimal(6,2)
  facturas_por_usuario       decimal(6,2)

  generado_at            timestamp    [default: `now()`]

  indexes {
    (anio, mes)
    area
  }

  Note: 'Agregado mensual de productividad por área/equipo'
}

Table agg_calidad_servicio_mes {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  anio                   integer      [not null]
  mes                    integer      [not null]

  total_pedidos          integer      [default: 0]
  pedidos_completos      integer      [default: 0]
  pedidos_parciales      integer      [default: 0]
  pedidos_con_novedades  integer      [default: 0]

  total_remisiones       integer      [default: 0]
  remisiones_con_danos   integer      [default: 0]
  remisiones_con_faltantes integer   [default: 0]

  total_facturas_dian    integer      [default: 0]
  facturas_aprobadas_dian integer    [default: 0]
  facturas_rechazadas_dian integer   [default: 0]

  tasa_pedidos_completos decimal(5,2) [note: '%']
  tasa_novedades         decimal(5,2) [note: '%']
  tasa_aprobacion_dian   decimal(5,2) [note: '%']

  tiempo_prom_despacho   decimal(6,2) [note: 'Días promedio hasta pedido completo']
  tiempo_prom_devolucion decimal(6,2) [note: 'Días promedio de alquiler']

  generado_at            timestamp    [default: `now()`]

  indexes {
    (anio, mes)
  }

  Note: 'Agregado mensual de indicadores de calidad de servicio'
}

Table agg_analisis_clientes {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  fecha_corte            date         [not null]
  cliente_id             uuid         [not null, ref: > clientes.id]

  // RFM (Recency, Frequency, Monetary)
  dias_ultima_factura    integer      [note: 'R: Recency - días desde última factura']
  total_facturas_12m     integer      [note: 'F: Frequency - facturas últimos 12 meses']
  valor_total_12m        decimal(18,2) [note: 'M: Monetary - valor facturado últimos 12 meses']

  score_r                integer      [note: '1-5 (5 = más reciente)']
  score_f                integer      [note: '1-5 (5 = más frecuente)']
  score_m                integer      [note: '1-5 (5 = mayor valor)']
  score_rfm              integer      [note: 'Suma de R+F+M (3-15)']

  segmento               varchar(30)  [note: 'Campeones|Leales|Potenciales|En Riesgo|Perdidos']

  // Métricas adicionales
  total_obras_activas    integer      [default: 0]
  ticket_promedio        decimal(18,2)
  dias_promedio_pago     decimal(6,2)
  tiene_mora             boolean      [default: false]

  generado_at            timestamp    [default: `now()`]

  indexes {
    (cliente_id, fecha_corte)
    segmento
    score_rfm
  }

  Note: '''
    Análisis RFM de clientes para segmentación.

    Segmentos:
    - Campeones (RFM 12-15): Clientes top
    - Leales (RFM 9-11): Clientes frecuentes
    - Potenciales (RFM 6-8): Oportunidad de crecimiento
    - En Riesgo (RFM 4-5): Requieren atención
    - Perdidos (RFM 3): Reactivación urgente
  '''
}

Table agg_forecast_facturacion {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  anio                   integer      [not null]
  mes                    integer      [not null]
  tipo_forecast          varchar(20)  [note: 'optimista|realista|pesimista']

  pedidos_pendientes     integer      [default: 0]
  valor_pedidos_pendientes decimal(18,2) [default: 0]

  alquileres_activos     integer      [default: 0]
  valor_alquileres_mes   decimal(18,2) [default: 0]

  contratos_vigentes     integer      [default: 0]
  valor_contratos_mes    decimal(18,2) [default: 0]

  forecast_mes           decimal(18,2) [note: 'Proyección de facturación del mes']
  margen_error           decimal(5,2) [note: '% de margen de error']

  generado_at            timestamp    [default: `now()`]

  indexes {
    (anio, mes)
    tipo_forecast
  }

  Note: 'Proyección de facturación mensual basada en pedidos, alquileres y contratos activos'
}

Table agg_transporte_mes {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  anio                   integer      [not null]
  mes                    integer      [not null]
  conductor_id           uuid         [ref: > conductores.id]
  vehiculo_id            uuid         [ref: > vehiculos.id]
  zona                   varchar(50)

  total_viajes           integer      [default: 0]
  km_total               decimal(12,2) [default: 0]
  peso_total_ton         decimal(12,3) [default: 0]
  volumen_total_m3       decimal(12,3) [default: 0]

  valor_transporte_facturado decimal(18,2) [default: 0]
  valor_liquidacion_conductor decimal(18,2) [default: 0]
  margen_transporte      decimal(18,2) [note: 'facturado - liquidación']

  viajes_calificados     integer      [default: 0, note: 'Viajes que cumplieron criterios']
  tasa_calificacion      decimal(5,2) [note: '%']

  generado_at            timestamp    [default: `now()`]

  indexes {
    (anio, mes)
    conductor_id
    vehiculo_id
  }

  Note: 'Agregado mensual de indicadores de transporte por conductor y vehículo'
}

Table agg_dashboard_ejecutivo {
  id                     uuid         [pk, default: `gen_random_uuid()`]
  fecha_corte            date         [not null]
  periodo                varchar(20)  [note: 'dia|semana|mes|trimestre|ano']

  // Comercial
  clientes_nuevos        integer      [default: 0]
  clientes_activos       integer      [default: 0]
  cotizaciones_nuevas    integer      [default: 0]
  tasa_conversion        decimal(5,2)

  // Operacional
  pedidos_nuevos         integer      [default: 0]
  pedidos_completos      integer      [default: 0]
  pedidos_incompletos    integer      [default: 0]
  remisiones_salida      integer      [default: 0]
  remisiones_entrada     integer      [default: 0]

  // Inventario
  stock_disponible_valor decimal(18,2)
  stock_en_alquiler_valor decimal(18,2)
  tasa_rotacion_global   decimal(6,2)

  // Financiero
  facturacion_periodo    decimal(18,2)
  cobros_periodo         decimal(18,2)
  cartera_total          decimal(18,2)
  cartera_vencida        decimal(18,2)

  // Calidad
  tasa_pedidos_completos decimal(5,2)
  tasa_novedades         decimal(5,2)
  tasa_aprobacion_dian   decimal(5,2)

  generado_at            timestamp    [default: `now()`]

  indexes {
    (fecha_corte, periodo)
  }

  Note: '''
    Dashboard ejecutivo con KPIs clave del negocio.
    Se genera diariamente, semanalmente, mensualmente, trimestralmente y anualmente.
  '''
}

// ============================================================
// CONTROL DE PROCESOS ETL
// ============================================================

Table etl_log {
  id                bigserial    [pk]
  proceso           varchar(100) [not null, note: 'Nombre del proceso ETL']
  fecha_ejecucion   timestamp    [default: `now()`]
  estado            varchar(20)  [note: 'INICIADO|COMPLETADO|ERROR']
  duracion_seg      integer      [note: 'Duración en segundos']
  registros_procesados integer   [note: 'Cantidad de registros procesados']
  error_mensaje     text         [note: 'Mensaje de error si aplica']

  indexes {
    proceso
    fecha_ejecucion
  }

  Note: 'Log de ejecuciones de procesos ETL — monitoreo y auditoría'
}
