// ============================================================
// G&H OBRAS Y ESTRUCTURAS METALICAS S.A.S
// Sistema de Gestión Comercial, Cotizaciones, Inventarios y Facturación
// Base de Datos: PostgreSQL — Versión 1.1
// Fecha: 2026-07-04 (actualizado SEM-27 con entrevistas de feedback)
// ============================================================

Project gyh_sistema {
  database_type: 'PostgreSQL'
  Note: '''
    Sistema de Gestión para G&H Obras y Estructuras Metálicas S.A.S.
    NIT: 901.218.896-8 — Bogotá, Colombia
    Módulos: Clientes · Cotizaciones · Contratos · Inventarios · Facturación · Auditoría
    Métricas de escala: ~180 clientes, hasta 50 obras/cliente, 3-4 frentes/obra,
    6-12 cotizaciones/semana por dibujante, ~50 prospectos nuevos/mes.
    SEM-27: Pedidos parciales · Centros de costo · Retenciones por tipo · Catálogos duales
            Rol Despachador · Rol Recepción · CUFE/Radian · Equipo ajeno · Cronograma diario
  '''
}

// ============================================================
// ENUMERACIONES GLOBALES
// ============================================================

Enum rol_usuario {
  superadmin    [note: 'Configuración global del sistema — parámetros de trayecto, reglas de negocio, tarifas']
  admin         [note: 'Administrador del sistema']
  comercial     [note: 'Equipo de ventas y cotizaciones; incluye ingenieros de campo; autoriza despachos']
  dibujante     [note: 'Modelamiento técnico en AutoCAD']
  contabilidad  [note: 'Validación financiera y supervisión de cartera']
  facturacion   [note: 'Genera facturas y proformas, envía a Siigo/DIAN, gestiona centros de costo y retenciones']
  juridica      [note: 'Validación documental y contratos']
  almacen       [note: 'Jefe de almacén, inventarios y agenda de transporte']
  conductor     [note: 'Transporte de equipos']
  despachador   [note: 'Conteo físico de equipos en bodega (entrada y salida); clasifica estado en devoluciones']
  recepcion     [note: 'Cronograma diario de recogidas y cortes — Viviana']
}

Enum tipo_id {
  NIT
  CC
  CE
  Pasaporte
}

Enum ciudad_sucursal {
  bogota
  ibague
  armenia
}

Enum estado_cliente {
  prospecto     [note: 'Lead sin proceso de registro formal']
  en_revision   [note: 'Checklist en proceso de aprobación']
  aprobado      [note: 'Todos los conceptos favorables']
  rechazado     [note: 'Al menos un área dio concepto no favorable']
  inactivo
}

Enum regimen_iva_tipo {
  comun
  simplificado
  especial
}

Enum area_aprobacion {
  contabilidad
  juridica
  comercial
}

Enum estado_aprobacion {
  pendiente
  favorable
  no_favorable
}

Enum tipo_contacto {
  encargado_pagos
  recepcion_facturas
  general
}

Enum tipo_documento_registro {
  rut
  camara_comercio
  cedula_representante
  estados_financieros
  autorizacion_centrales_riesgo
  formulario_registro_ft_ac_001
  carta_presentacion
  certificado_bancario
  otro
}

Enum estado_validacion_doc {
  pendiente
  aprobado
  rechazado
  requiere_actualizacion
}

Enum estado_obra {
  activa
  pausada
  finalizada
  cancelada
}

Enum tipo_producto {
  andamio
  formaleta
  maquinaria
  accesorio
  herramienta
  otro
}

Enum unidad_medida {
  unidad
  metro
  metro_cuadrado
  juego
  kit
}

Enum estado_cotizacion {
  borrador
  en_revision
  enviada_cliente
  aprobada_cliente
  rechazada_cliente
  vencida
  convertida_orden
}

Enum tipo_item_cotizacion {
  venta         [note: 'Productos existentes en catálogo']
  alquiler      [note: 'Maquinaria temporal — se calcula por días desde pedido completo']
  transporte_ida
  transporte_vuelta
  reposicion    [note: 'Cobro por pérdida o no devolución']
  accesorio
}

Enum formato_archivo {
  dwg
  dxf
  pdf
  xlsx
  xls
  png
  jpg
}

Enum tipo_archivo_plano {
  plano_autocad
  desglose_materiales
  cotizacion_pdf
  otro
}

Enum estado_orden {
  pendiente
  en_firma
  activa
  finalizada
  cancelada
}

Enum estado_contrato {
  borrador
  enviado_firma
  firmado
  cancelado
}

Enum tipo_remision {
  salida             [note: 'Despacho de equipos a obra']
  entrada_devolucion [note: 'Retorno de alquiler']
  entrada_reposicion [note: 'Cobro por faltante']
}

Enum estado_remision {
  programada
  en_transito
  entregada
  recibida
  con_novedad
}

Enum estado_item_remision {
  pendiente
  entregado_ok
  entregado_parcial
  danado         [note: 'Daño que genera novedad y posible cobro al cliente']
  baja           [note: 'Equipo dado de baja — destrucción irreparable o pérdida definitiva; se registra internamente, no genera reposición']
  mantenimiento  [note: 'Equipo reparable — G&H asume el costo, no se factura al cliente']
  faltante       [note: 'No retornó — genera ítem de reposición (cobro al cliente según catálogo)']
  ajeno          [note: 'Equipo que no pertenece a G&H — devolver a empresa externa']
}

Enum proveedor_transporte {
  gyh     [note: 'G&H provee y factura el transporte — cobro por peso Y volumen (el que resulte mayor)']
  cliente [note: 'El cliente gestiona su propio transporte — no se cobra flete por G&H']
}

Enum tipo_origen_contrato {
  interno  [note: 'Contrato ya existente con el cliente — activa operaciones directamente sin firma']
  externo  [note: 'Nuevo contrato para cliente externo o primer contrato — requiere firma Ooku']
}

Enum ciclo_cobro {
  mes_vencido  [note: 'Cobro el mes siguiente al período del servicio (default)']
  quincenal
  semanal
  al_cierre    [note: 'Facturación al cierre de la obra']
}

Enum estado_agenda {
  programado
  en_curso
  completado
  cancelado
  reprogramado
}

Enum estado_factura {
  pendiente
  enviada
  pagada_parcial
  pagada
  vencida
  en_cartera
  anulada
}

Enum metodo_pago {
  transferencia
  efectivo
  cheque
  otro
}

Enum estado_cartera {
  nueva
  en_gestion
  acuerdo_pago
  demanda
  castigada
  recuperada
}

Enum tipo_notificacion {
  aprobacion_pendiente
  cotizacion_aprobada
  contrato_firmado
  recogida_programada
  devolucion_pendiente
  factura_vencida
  cartera_alerta
  sistema
}

// Nuevos enums SEM-27 ────────────────────────────────────────

Enum estado_pedido {
  pendiente   [note: 'Sin remisiones de salida generadas aún']
  parcial     [note: 'Con al menos una remisión, pedido incompleto — el alquiler NO ha iniciado']
  completo    [note: 'Todo el pedido fue despachado — inicia contador de días de alquiler']
  cancelado   [note: 'Cancelado por la obra; motivo registrado']
}

Enum modalidad_factura {
  por_remision  [note: 'Una factura por cada remisión o contratista']
  consolidada   [note: 'Una sola factura con todos los ítems del período (transporte siempre va separado)']
  por_valor     [note: 'El usuario define el monto; el sistema agrega ítems hasta alcanzarlo']
}

Enum estado_radian {
  sin_enviar
  enviada_dian    [note: 'Enviada a la DIAN — CUFE generado']
  aceptada_dian   [note: 'Aceptada y marcada por el cliente con sistema contable (triple check)']
  rechazada_dian  [note: 'Rechazada por la DIAN — revisar errores']
  sin_confirmar   [note: 'Cliente con dominio público (Gmail/Hotmail) — no dará check automático; Cartera llama']
}

Enum tipo_dominio_correo {
  corporativo  [note: 'Sistema contable propio — da triple check automático en DIAN']
  publico      [note: 'Gmail, Hotmail, Yahoo — nunca dará el check; seguimiento telefónico por Cartera']
}

// ============================================================
// MÓDULO: USUARIOS Y SEGURIDAD
// ============================================================

Table usuarios {
  id          uuid        [pk, default: `gen_random_uuid()`]
  nombre      varchar(200) [not null]
  email       varchar(200) [unique, not null]
  password_hash varchar(500) [not null]
  rol         rol_usuario  [not null]
  activo      boolean      [default: true]
  created_at  timestamp    [default: `now()`]
  updated_at  timestamp    [default: `now()`]

  Note: 'Usuarios del sistema con control de acceso por rol (RBAC) — 11 roles'
}

// ============================================================
// MÓDULO: AUDITORÍA Y NOTIFICACIONES (Transversal)
// ============================================================

Table auditoria {
  id               bigserial    [pk]
  usuario_id       uuid         [ref: > usuarios.id]
  accion           varchar(100) [not null, note: 'CREATE, UPDATE, DELETE, LOGIN, etc.']
  tabla_afectada   varchar(100) [not null]
  registro_id      varchar(100) [note: 'ID del registro modificado']
  datos_anteriores jsonb
  datos_nuevos     jsonb
  ip_address       varchar(50)
  user_agent       text
  created_at       timestamp    [default: `now()`]

  indexes {
    usuario_id
    tabla_afectada
    created_at
  }

  Note: 'Log inmutable: quién hizo qué y cuándo — requerimiento transversal del sistema'
}

Table notificaciones {
  id               bigserial    [pk]
  usuario_id       uuid         [not null, ref: > usuarios.id]
  tipo             tipo_notificacion [not null]
  titulo           varchar(300) [not null]
  mensaje          text         [not null]
  url_referencia   varchar(500)
  leida            boolean      [default: false]
  leida_at         timestamp
  created_at       timestamp    [default: `now()`]

  indexes {
    usuario_id
    leida
  }

  Note: 'Motor de notificaciones para empujar aprobaciones y alertas logísticas'
}

// ============================================================
// MÓDULO: CLIENTES
// (Basado en formulario FT-AC-001 VERSION 2.0)
// ============================================================

Table clientes {
  id                      uuid        [pk, default: `gen_random_uuid()`]

  // I. INFORMACIÓN GENERAL (FT-AC-001 Sección I)
  razon_social            varchar(300) [not null]
  nombre_comercial        varchar(300)
  tipo_identificacion     tipo_id      [not null]
  numero_identificacion   varchar(50)  [unique, not null]
  ciudad                  varchar(100)
  direccion               text
  telefono                varchar(50)
  fax                     varchar(50)
  representante_legal     varchar(200)
  id_representante        varchar(50)
  clase_sociedad          varchar(100)
  regimen                 varchar(100)

  // V. INFORMACIÓN TRIBUTARIA (FT-AC-001 Sección V)
  tiene_camara_comercio   boolean      [default: false]
  fecha_camara_comercio   date
  matricula_camara        varchar(100)
  codigo_ciiu             varchar(20)
  actividad_economica     text
  codigo_ica              varchar(20)
  tarifa_ica              decimal(5,2)
  rte_fuente              decimal(5,2)
  rte_ica                 decimal(5,2)
  regimen_iva             regimen_iva_tipo
  gran_contribuyente      boolean      [default: false]
  autorretenedor          boolean      [default: false]

  // Facturación especial (SEM-27)
  nombre_facturacion      varchar(300) [note: 'Nombre para la factura cuando el pagador difiere del contratante (ej: fiducia vs. consorcio Bronz)']
  tipo_dominio_correo     tipo_dominio_correo [note: 'Corporativo = triple check DIAN automático; Público = seguimiento telefónico por Cartera']
  tiene_sistema_contable  boolean      [default: false, note: 'Define si el cliente puede dar el triple check en DIAN o requiere llamada']

  // Condiciones de pago (SEM-27)
  dias_tramitacion_facturas integer     [note: 'Días específicos del cliente para tramitar facturas (ej: paga solo los martes)']
  ciclo_cobro               ciclo_cobro [default: 'mes_vencido', note: 'Ciclo de cobro: mes vencido es el default']
  notas_condiciones_pago    text        [note: 'Instrucciones especiales de facturación (horarios, contacto, portal específico)']

  // Control del sistema
  estado_cliente          estado_cliente [default: 'prospecto']
  codigo_revision         varchar(50)  [unique, note: 'Código auto-generado de revisión del registro']
  ciudad_sucursal         ciudad_sucursal
  creado_por              uuid         [ref: > usuarios.id]
  created_at              timestamp    [default: `now()`]
  updated_at              timestamp    [default: `now()`]

  indexes {
    numero_identificacion
    estado_cliente
    ciudad_sucursal
  }

  Note: 'Registro central de clientes — ~180 clientes migración inicial (130 Bogotá, 50 Ibagué/Armenia)'
}

Table contactos_cliente {
  id             uuid         [pk, default: `gen_random_uuid()`]
  cliente_id     uuid         [not null, ref: > clientes.id]

  // II. INFORMACIÓN DE CONTACTO (FT-AC-001 Sección II)
  tipo_contacto  tipo_contacto [not null]
  nombre         varchar(200) [not null]
  telefono       varchar(50)
  ext            varchar(10)
  correo         varchar(200)
  direccion      text
  horario        varchar(200)
  plazos_pago    varchar(200)

  Note: 'Sección II FT-AC-001: encargado de pagos y recepción de facturas electrónicas'
}

Table referencias_bancarias {
  id               uuid         [pk, default: `gen_random_uuid()`]
  cliente_id       uuid         [not null, ref: > clientes.id]

  // III. REFERENCIAS BANCARIAS (FT-AC-001 Sección III)
  banco            varchar(200) [not null]
  sucursal         varchar(200)
  telefono         varchar(50)
  direccion        text
  persona_contacto varchar(200)
  orden            integer      [default: 1]

  Note: 'Sección III FT-AC-001: hasta 2 referencias bancarias por cliente'
}

Table referencias_comerciales {
  id         uuid         [pk, default: `gen_random_uuid()`]
  cliente_id uuid         [not null, ref: > clientes.id]

  // IV. REFERENCIAS COMERCIALES (FT-AC-001 Sección IV)
  nombre     varchar(200) [not null]
  telefono   varchar(50)
  celular    varchar(50)
  direccion  text
  orden      integer      [default: 1]

  Note: 'Sección IV FT-AC-001: hasta 2 referencias comerciales por cliente'
}

Table accionistas {
  id              uuid         [pk, default: `gen_random_uuid()`]
  cliente_id      uuid         [not null, ref: > clientes.id]

  // VII. SOCIOS Y/O ACCIONISTAS (FT-AC-001 Sección VII)
  nombre_completo varchar(300) [not null]
  tipo_id         tipo_id      [not null]
  numero_id       varchar(50)  [not null]
  es_pep          boolean      [default: false, note: 'Persona Expuesta Políticamente']
  descripcion_pep text

  Note: 'Sección VII FT-AC-001: accionistas con >5% del capital social'
}

Table autorizacion_centrales_riesgo {
  id                    uuid    [pk, default: `gen_random_uuid()`]
  cliente_id            uuid    [unique, not null, ref: > clientes.id]
  firma_representante_url varchar(500)
  huella_url            varchar(500)
  fecha_firma           date
  nombre_firmante       varchar(200)
  cedula_firmante       varchar(50)

  Note: 'Autorización Ley 1581/2012 — Consulta centrales de riesgo y listas LAFT (Circular 09/2016)'
}

// ============================================================
// FLUJO DE APROBACIÓN DE CLIENTES
// ============================================================

Table aprobaciones_cliente {
  id             uuid         [pk, default: `gen_random_uuid()`]
  cliente_id     uuid         [not null, ref: > clientes.id]
  area           area_aprobacion [not null]
  estado         estado_aprobacion [default: 'pendiente']
  concepto       text         [note: 'Comentario obligatorio que justifica la decisión — no se puede guardar sin él']
  es_favorable   boolean
  aprobado_por   uuid         [ref: > usuarios.id]
  fecha_concepto timestamp
  created_at     timestamp    [default: `now()`]
  updated_at     timestamp    [default: `now()`]

  indexes {
    (cliente_id, area) [unique, note: 'Un concepto por área por cliente']
  }

  Note: 'Checklist digital de aprobación: las 3 áreas deben dar concepto antes de proceder al contrato'
}

Table documentos_registro {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  cliente_id          uuid    [not null, ref: > clientes.id]
  tipo_documento      tipo_documento_registro [not null]
  nombre_archivo      varchar(300) [not null]
  url_archivo         varchar(500) [not null]
  estado_validacion   estado_validacion_doc [default: 'pendiente']
  validado_por        uuid    [ref: > usuarios.id]
  fecha_validacion    timestamp
  comentario          text
  uploaded_by         uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]

  Note: 'Documentos del checklist de validación: RUT, Cámara, Cédula RL, Estados Financieros, etc.'
}

// ============================================================
// MÓDULO: OBRAS Y FRENTES DE TRABAJO
// ============================================================

Table obras {
  id         uuid         [pk, default: `gen_random_uuid()`]
  cliente_id uuid         [not null, ref: > clientes.id]

  // VIII. INFORMACIÓN DE OBRA (FT-AC-001 Sección VIII)
  nombre     varchar(300) [not null]
  direccion  text         [not null]
  ciudad     varchar(100)
  telefono   varchar(50)
  correo     varchar(200)
  encargado  varchar(200)
  estado     estado_obra  [default: 'activa']
  created_at timestamp    [default: `now()`]
  updated_at timestamp    [default: `now()`]

  indexes {
    cliente_id
    estado
  }

  Note: 'Obras por cliente — hasta 50 por cliente según métricas de migración'
}

Table frentes_obra {
  id          uuid         [pk, default: `gen_random_uuid()`]
  obra_id     uuid         [not null, ref: > obras.id]
  nombre      varchar(200) [not null]
  descripcion text
  estado      estado_obra  [default: 'activa']
  created_at  timestamp    [default: `now()`]

  Note: 'Frentes dentro de una obra — entre 3 y 4 frentes por obra; el equipo se puede prestar entre frentes'
}

// ============================================================
// MÓDULO: CATÁLOGO DE PRODUCTOS
// ============================================================

Table catalogo_productos {
  id                   uuid         [pk, default: `gen_random_uuid()`]
  codigo               varchar(100) [unique, not null]
  nombre               varchar(300) [not null]
  descripcion          text
  categoria            varchar(100)
  tipo_producto        tipo_producto [not null]
  unidad_medida        unidad_medida [default: 'unidad']

  // Precios por modalidad (catálogo general anual — actualizado por Recepción)
  precio_venta         decimal(15,2)
  precio_alquiler_dia  decimal(15,2) [note: 'Tarifa diaria — inicia desde fecha de pedido completo hasta devolución']
  precio_reposicion    decimal(15,2) [note: 'Valor comercial en caso de pérdida/daño irreparable']

  // Cálculo por área
  calcula_por_m2       boolean       [default: false]
  precio_por_m2        decimal(15,2)

  // Clasificación facturación (SEM-27)
  centro_costo         varchar(5)    [note: '13=alquiler · 14=venta_reposicion — aplicado automáticamente en factura']
  unidad_negocio       varchar(50)   [note: 'formaleta_metalica|multidireccional|transporte|formaleta_plastica|formaleta_tradicional']
  codigo_tipo          varchar(10)   [note: 'alquiler|venta — no mezclar; al hacer venta no tomar de inventario de alquiler']
  precio_transporte_calculo varchar(20) [note: 'peso_volumen|toneladas — el cobro real de transporte es por lo que ocupe (peso O volumen que llene el camión)']

  // Inventario
  stock_actual         integer       [default: 0]
  stock_minimo         integer       [default: 0]

  imagen_url           varchar(500)
  activo               boolean       [default: true]
  codigo_revision      varchar(50)   [note: 'Código auto de versión del producto']
  created_at           timestamp     [default: `now()`]
  updated_at           timestamp     [default: `now()`]

  Note: 'Catálogo general anual — actualizado por Recepción cada año y distribuido a todas las áreas'
}

// Precios especiales por cliente (SEM-27)
Table catalogo_precios_cliente {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  cliente_id          uuid    [not null, ref: > clientes.id]
  producto_id         uuid    [not null, ref: > catalogo_productos.id]
  precio_alquiler_dia decimal(15,2)
  precio_venta        decimal(15,2)
  precio_reposicion   decimal(15,2)
  vigente_desde       date    [not null]
  vigente_hasta       date
  acuerdo_comercial   text    [not null, note: 'Descripción del acuerdo — notificado por escrito a Facturación por el Comercial']
  registrado_por      uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]
  updated_at          timestamp [default: `now()`]

  indexes {
    (cliente_id, producto_id)
    vigente_desde
  }

  Note: 'Precios especiales por cliente — el Comercial los acuerda y notifica por escrito a Facturación (ej: Marval con 30 obras)'
}

// Configuración de retenciones por tipo de concepto (SEM-27)
Table retenciones_config {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  tipo_concepto       varchar(30) [not null, note: 'alquiler|transporte|venta|reposicion']
  nombre_retencion    varchar(30) [not null, note: 'rte_fuente|rte_ica|iva']
  porcentaje          decimal(5,2) [not null]
  centro_costo        varchar(5)  [note: '13=alquiler · 14=venta_reposicion']
  vigente_desde       date    [not null]
  vigente_hasta       date
  nota                text    [note: 'Ej: Transporte Rte. Fuente 1% — diferente de alquiler; no mezclar en una factura o Siigo la rechaza']
  creado_por          uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]

  Note: 'Retenciones por tipo de concepto — transporte y alquiler tienen tasas distintas; si se mezclan, Siigo rechaza la factura'
}

// ============================================================
// MÓDULO: COTIZACIONES
// ============================================================

Table cotizaciones {
  id                   uuid         [pk, default: `gen_random_uuid()`]
  numero_cotizacion    varchar(50)  [unique, not null]
  cliente_id           uuid         [not null, ref: > clientes.id]
  obra_id              uuid         [ref: > obras.id]
  dibujante_id         uuid         [ref: > usuarios.id]
  comercial_id         uuid         [ref: > usuarios.id]
  estado               estado_cotizacion [default: 'borrador']

  // Tipos de negocio habilitados
  incluye_venta        boolean      [default: false]
  incluye_alquiler     boolean      [default: false]
  incluye_transporte   boolean      [default: false]
  incluye_reposicion   boolean      [default: false]

  // Totales calculados
  subtotal             decimal(18,2) [default: 0]
  descuento            decimal(18,2) [default: 0]
  iva                  decimal(18,2) [default: 0]
  total                decimal(18,2) [default: 0]

  // Archivos del proceso (AutoCAD → Excel → PDF)
  archivo_plano_url    varchar(500)
  archivo_excel_url    varchar(500)  [note: 'Desglose de materiales exportado desde AutoCAD']
  pdf_cotizacion_url   varchar(500)  [note: 'PDF final con valores comerciales agregados']

  // Indicador de catálogo especial
  usa_precios_especiales boolean     [default: false, note: 'true si el cliente tiene catalogo_precios_cliente vigente']

  notas_dibujante      text
  notas_comercial      text
  horas_modelamiento   decimal(4,2)  [note: 'Métrica: actualmente 4-6 horas en AutoCAD']
  codigo_revision      varchar(50)
  created_at           timestamp     [default: `now()`]
  updated_at           timestamp     [default: `now()`]

  indexes {
    cliente_id
    estado
    dibujante_id
    created_at
  }

  Note: 'Cotizaciones: 6-12 por semana por dibujante. Soporta venta, alquiler, transporte y reposición'
}

Table cotizacion_items {
  id                   uuid          [pk, default: `gen_random_uuid()`]
  cotizacion_id        uuid          [not null, ref: > cotizaciones.id]
  frente_id            uuid          [ref: > frentes_obra.id]
  producto_id          uuid          [not null, ref: > catalogo_productos.id]
  tipo_item            tipo_item_cotizacion [not null]
  cantidad             decimal(12,3) [default: 1]
  area_m2              decimal(12,2) [note: 'Para productos que calculan por metro cuadrado']
  precio_unitario      decimal(15,2) [not null]
  precio_por_m2        decimal(15,2)
  dias_alquiler        integer       [note: 'Para ítems de alquiler: desde pedido completo hasta devolución']
  // Transporte: peso Y volumen (SEM-27)
  proveedor_transporte proveedor_transporte [note: 'G&H provee y cobra el flete, o el cliente lo gestiona por su cuenta']
  peso_kg              decimal(10,2) [note: 'Peso del envío en kg — para cálculo de transporte']
  volumen_m3           decimal(10,2) [note: 'Volumen del envío en m³ — si llena el camión se cobra la tarifa completa']
  subtotal             decimal(18,2) [not null]
  descripcion_adicional text

  Note: 'Líneas de cotización. Transporte: G&H cobra por peso Y volumen (el mayor); si el cliente provee transporte, no se cobra flete'
}

Table archivos_planos {
  id             uuid    [pk, default: `gen_random_uuid()`]
  cotizacion_id  uuid    [not null, ref: > cotizaciones.id]
  nombre_archivo varchar(300) [not null]
  formato        formato_archivo [not null]
  url_archivo    varchar(500)   [not null]
  tipo_archivo   tipo_archivo_plano [not null]
  uploaded_by    uuid    [ref: > usuarios.id]
  created_at     timestamp [default: `now()`]

  Note: 'Planos AutoCAD (DWG/DXF), exports Excel y PDFs de cotización'
}

// ============================================================
// MÓDULO: CONTRATOS Y ÓRDENES DE COMPRA
// ============================================================

Table ordenes_compra {
  id                    uuid    [pk, default: `gen_random_uuid()`]
  numero_orden          varchar(50) [unique, not null]
  cotizacion_id         uuid    [not null, ref: > cotizaciones.id]
  cliente_id            uuid    [not null, ref: > clientes.id]
  obra_id               uuid    [ref: > obras.id]
  estado                estado_orden [default: 'pendiente']
  fecha_inicio          date
  fecha_estimada_fin    date
  fecha_fin_real        date
  notas                 text
  created_at            timestamp [default: `now()`]
  updated_at            timestamp [default: `now()`]

  Note: 'Orden de compra generada una vez el cliente aprueba la cotización'
}

Table contratos {
  id                      uuid    [pk, default: `gen_random_uuid()`]
  numero_contrato         varchar(50) [unique, not null]
  orden_compra_id         uuid    [unique, not null, ref: > ordenes_compra.id]
  cliente_id              uuid    [not null, ref: > clientes.id]
  estado                  estado_contrato [default: 'borrador']

  // Integración con firma electrónica (DocuSign / Okc)
  plataforma_firma        varchar(100) [note: 'DocuSign, Okc u otra plataforma']
  id_documento_externo    varchar(200) [note: 'ID del documento en la plataforma de firma']
  url_documento_firmado   varchar(500)
  fecha_envio_firma       timestamp
  fecha_firma             timestamp
  firmado_por             varchar(200)

  created_at              timestamp [default: `now()`]
  updated_at              timestamp [default: `now()`]

  Note: 'Contratos con integración a firma electrónica — trigger automático a operaciones al firmarse'
}

// ============================================================
// MÓDULO: INVENTARIOS Y LOGÍSTICA
// ============================================================

// Pedidos de despacho (SEM-27)
Table pedidos {
  id                     uuid    [pk, default: `gen_random_uuid()`]
  numero_pedido          varchar(50) [unique, not null]
  orden_compra_id        uuid    [not null, ref: > ordenes_compra.id]
  obra_id                uuid    [not null, ref: > obras.id]
  frente_id              uuid    [ref: > frentes_obra.id]
  estado                 estado_pedido [default: 'pendiente']
  fecha_pedido           date    [not null]
  fecha_entrega_estimada date
  autorizado_por         uuid    [ref: > usuarios.id, note: 'Ingeniero o Comercial que autoriza el despacho']
  fecha_autorizacion     timestamp
  motivo_cancelacion     text
  cancelado_por          uuid    [ref: > usuarios.id]
  fecha_alquiler_inicio  date    [note: 'Establecida automáticamente cuando estado = completo — desde aquí corren los días de alquiler']
  notas                  text
  created_at             timestamp [default: `now()`]
  updated_at             timestamp [default: `now()`]

  indexes {
    orden_compra_id
    estado
    fecha_pedido
  }

  Note: 'Un pedido puede enviarse en múltiples viajes parciales. El alquiler SOLO inicia cuando el pedido queda completo'
}

Table pedido_items {
  id                uuid    [pk, default: `gen_random_uuid()`]
  pedido_id         uuid    [not null, ref: > pedidos.id]
  producto_id       uuid    [not null, ref: > catalogo_productos.id]
  cantidad_pedida   integer [not null]
  cantidad_enviada  integer [default: 0, note: 'Acumulado de remisiones de salida vinculadas a este pedido']
  created_at        timestamp [default: `now()`]

  Note: 'Ítems de un pedido — cantidad_enviada se actualiza con cada remisión parcial hasta igualar cantidad_pedida'
}

Table conductores {
  id           uuid    [pk, default: `gen_random_uuid()`]
  nombre       varchar(200) [not null]
  cedula       varchar(50)  [unique, not null]
  telefono     varchar(50)
  celular      varchar(50)
  tipo_vehiculo varchar(100)
  placa        varchar(20)
  activo       boolean  [default: true]
  created_at   timestamp [default: `now()`]

  Note: 'Conductores para transporte de equipos a obras — definen el estado inicial del equipo en devoluciones'
}

Table remisiones {
  id               uuid    [pk, default: `gen_random_uuid()`]
  numero_remision  varchar(50) [unique, not null]
  orden_compra_id  uuid    [not null, ref: > ordenes_compra.id]
  pedido_id        uuid    [ref: > pedidos.id, note: 'Pedido al que pertenece esta remisión (puede ser parcial)']
  frente_id        uuid    [ref: > frentes_obra.id]
  frente_ajuste_id uuid    [ref: > frentes_obra.id, note: 'Frente al que se reasignó cuando hay préstamo entre frentes']
  tipo_remision    tipo_remision [not null]
  es_parcial       boolean [default: false, note: 'true si el pedido asociado no está aún completo']
  fecha_remision   date    [not null]
  hora_remision    time    [note: 'Hora exacta del despacho o recepción']
  responsable_id   uuid    [ref: > usuarios.id]
  conductor_id     uuid    [ref: > conductores.id]
  vehiculo         varchar(100)
  placa            varchar(20)
  direccion_destino text
  observaciones    text
  estado           estado_remision [default: 'programada']
  // Verificación 3 fuentes en devolución (SEM-27)
  formato_conductor    text   [note: 'Registro del conductor: lo que dice haber traído']
  formato_despachador  text   [note: 'Conteo físico del despachador en bodega']
  fotos_porteria_urls  text[] [note: 'URLs de fotos de portería de la obra — evidencia salida']
  cruce_ajuste         text   [note: 'Justificación cuando se reasigna a otro frente por equipo prestado entre frentes']
  created_at       timestamp [default: `now()`]
  updated_at       timestamp [default: `now()`]

  indexes {
    orden_compra_id
    pedido_id
    tipo_remision
    fecha_remision
  }

  Note: 'Remisiones de salida y entrada al Kardex — incluye verificación de 3 fuentes en devoluciones'
}

Table remision_items {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  remision_id         uuid    [not null, ref: > remisiones.id]
  producto_id         uuid    [not null, ref: > catalogo_productos.id]
  cantidad_programada integer [not null]
  cantidad_real       integer
  estado_item         estado_item_remision [default: 'pendiente']
  novedad             text    [note: 'Descripción de daño, faltante, mantenimiento o equipo ajeno']
  clasificado_por     uuid    [ref: > usuarios.id, note: 'Conductor o Despachador que clasificó el estado']

  Note: 'Detalle de equipos por remisión — 5 estados: ok/dañado/mantenimiento/faltante/ajeno'
}

// Cronograma diario Recepción → Almacén (SEM-27)
Table cronograma_recogidas {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  fecha               date    [not null]
  obra_id             uuid    [not null, ref: > obras.id]
  cliente_id          uuid    [not null, ref: > clientes.id]
  numero_corte        varchar(50)
  fecha_corte         date
  estado              varchar(20) [default: 'programada', note: 'programada|parcial|completada|sin_recoger']
  registrado_por      uuid    [ref: > usuarios.id, note: 'Viviana — Recepción']
  notas               text
  created_at          timestamp [default: `now()`]
  updated_at          timestamp [default: `now()`]

  indexes {
    fecha
    estado
    obra_id
  }

  Note: 'Cronograma diario: Viviana (Recepción) lo crea; Almacén (Angie) actualiza con recogidas realizadas'
}

// Equipo ajeno recibido en devoluciones (SEM-27)
Table equipos_ajenos {
  id                  uuid    [pk, default: `gen_random_uuid()`]
  remision_id         uuid    [ref: > remisiones.id]
  descripcion         text    [not null]
  empresa_origen      varchar(200) [note: 'Empresa a quien pertenece el equipo']
  fecha_recepcion     date    [not null]
  estado              varchar(20) [default: 'en_bodega', note: 'en_bodega|devuelto']
  fecha_devolucion    date
  devuelto_a          varchar(200)
  notas               text
  registrado_por      uuid    [ref: > usuarios.id]
  created_at          timestamp [default: `now()`]

  Note: 'Equipo que no pertenece a G&H y llega en devoluciones — debe ser devuelto a la empresa correspondiente'
}

Table agenda_transporte {
  id                 uuid    [pk, default: `gen_random_uuid()`]
  remision_id        uuid    [not null, ref: > remisiones.id]
  conductor_id       uuid    [not null, ref: > conductores.id]
  fecha_programada   date    [not null]
  hora_inicio        time
  hora_fin           time
  direccion_recogida text
  direccion_destino  text    [not null]
  orden_compra_id    uuid    [ref: > ordenes_compra.id]
  estado_agenda      estado_agenda [default: 'programado']
  notas              text
  created_at         timestamp [default: `now()`]
  updated_at         timestamp [default: `now()`]

  indexes {
    conductor_id
    fecha_programada
  }

  Note: 'Agenda del jefe de almacén: conductores, horarios y direcciones de recogida'
}

// ============================================================
// MÓDULO: FACTURACIÓN Y CARTERA
// ============================================================

Table facturas {
  id               uuid    [pk, default: `gen_random_uuid()`]
  numero_factura   varchar(50)  [unique, not null]
  orden_compra_id  uuid    [not null, ref: > ordenes_compra.id]
  cliente_id       uuid    [not null, ref: > clientes.id]
  estado           estado_factura [default: 'pendiente']
  fecha_emision    date    [not null]
  fecha_vencimiento date   [not null]

  // Modalidad y centro de costo (SEM-27)
  modalidad_factura modalidad_factura [note: 'Por remisión, consolidada o por valor — transporte siempre va en factura separada']
  centro_costo      varchar(5)        [note: '13=alquiler · 14=venta_reposicion — aplicado automáticamente según líneas']

  // Valores con retenciones (según condiciones FT-AC-001 Sección VI)
  subtotal         decimal(18,2) [not null]
  descuento        decimal(18,2) [default: 0]
  iva              decimal(18,2) [default: 0]
  rte_fuente       decimal(18,2) [default: 0]
  rte_ica          decimal(18,2) [default: 0]
  total            decimal(18,2) [not null]
  saldo_pendiente  decimal(18,2) [not null]

  // Validación DIAN (SEM-27)
  // Integración Siigo → DIAN (no es directa — flujo: factura → Siigo → DIAN)
  cufe             varchar(200)  [note: 'Código Único de Factura Electrónica — generado por Siigo al transmitir a DIAN']
  siigo_estado     varchar(30)   [note: 'Estado en Siigo: sin_enviar|enviada_siigo|rechazada_siigo|transmitida_dian']
  siigo_enviada_at timestamp     [note: 'Fecha y hora en que se envió a Siigo']
  estado_radian    estado_radian [default: 'sin_enviar', note: 'Estado validado por Facturación en portal DIAN — fuente de verdad (no el estado de Siigo)']
  fecha_envio_dian timestamp     [note: 'Fecha de transmisión oficial a la DIAN (vía Siigo)']
  fecha_validacion_dian timestamp [note: 'Fecha en que Facturación confirmó el estado en portal DIAN']
  seguimiento_telefónico text    [note: 'Notas del seguimiento telefónico al cliente para confirmar recepción y procesamiento']

  pdf_url          varchar(500)
  notas            text
  created_at       timestamp [default: `now()`]
  updated_at       timestamp [default: `now()`]

  indexes {
    cliente_id
    estado
    fecha_vencimiento
  }

  Note: 'Facturación electrónica — CUFE + Radian son la prueba oficial (no el estado en Siigo)'
}

Table factura_items {
  id                 uuid    [pk, default: `gen_random_uuid()`]
  factura_id         uuid    [not null, ref: > facturas.id]
  cotizacion_item_id uuid    [ref: > cotizacion_items.id]
  descripcion        text    [not null]
  tipo_cobro         tipo_item_cotizacion [not null]
  cantidad           decimal(12,3) [default: 1]
  area_m2            decimal(12,2)
  dias_alquiler      integer [note: 'Calculado desde fecha pedido completo hasta devolución']
  precio_unitario    decimal(15,2) [not null]
  subtotal           decimal(18,2) [not null]
  // Retenciones por tipo de concepto (SEM-27)
  centro_costo       varchar(5)   [note: '13=alquiler · 14=venta_reposicion (automático por tipo_cobro)']
  retencion_tipo     varchar(30)  [note: 'rte_fuente|rte_ica|iva — diferente según tipo: transporte ≠ alquiler']
  retencion_porcentaje decimal(5,2) [note: 'Porcentaje aplicado automáticamente desde retenciones_config']

  Note: 'Líneas de factura con retención automática por tipo de concepto — no mezclar alquiler y transporte'
}

Table pagos {
  id              uuid    [pk, default: `gen_random_uuid()`]
  factura_id      uuid    [not null, ref: > facturas.id]
  monto           decimal(18,2) [not null]
  fecha_pago      date    [not null]
  hora_pago       time    [note: 'Hora del pago para trazabilidad completa']
  metodo_pago     metodo_pago [not null]
  referencia_pago varchar(200)
  registrado_por  uuid    [ref: > usuarios.id]
  notas           text
  created_at      timestamp [default: `now()`]

  Note: 'Registro de pagos — gestionado por Cartera (Facturación solo genera y valida envío a DIAN)'
}

Table cartera {
  id                   uuid    [pk, default: `gen_random_uuid()`]
  factura_id           uuid    [unique, not null, ref: > facturas.id]
  cliente_id           uuid    [not null, ref: > clientes.id]
  dias_mora            integer [default: 0]
  monto_mora           decimal(18,2) [default: 0]
  estado_gestion       estado_cartera [default: 'nueva']
  fecha_ultimo_contacto date
  tipo_contacto_cobro  varchar(20) [note: 'llamada_telefonica|email|visita — según tipo_dominio_correo del cliente']
  cufe_evidencia       varchar(200) [note: 'CUFE para mostrar al cliente que alega no haber recibido la factura']
  notas_gestion        text
  responsable_id       uuid    [ref: > usuarios.id]
  created_at           timestamp [default: `now()`]
  updated_at           timestamp [default: `now()`]

  Note: 'Gestión de cartera — Cartera es quien hace el seguimiento de pagos; Facturación solo valida envío a DIAN'
}
