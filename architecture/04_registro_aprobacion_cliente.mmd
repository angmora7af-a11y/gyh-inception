%%{init: {
  'theme': 'base',
  'themeVariables': {
    'primaryColor': '#1A365D',
    'primaryTextColor': '#FFFFFF',
    'primaryBorderColor': '#1A365D',
    'lineColor': '#4A5568',
    'secondaryColor': '#EDF2F7',
    'clusterBkg': '#2D3748',
    'clusterBorder': '#1A202C',
    'titleColor': '#FFFFFF',
    'edgeLabelBackground': '#F7FAFC',
    'fontFamily': 'Montserrat, sans-serif'
  }
}}%%

flowchart TD
    classDef azul       fill:#1A365D,color:#FFFFFF,stroke:#0F2440,stroke-width:2px
    classDef naranja     fill:#FF9F1C,color:#1A365D,stroke:#E8910A,stroke-width:2px,font-weight:bold
    classDef grisClaro   fill:#EDF2F7,color:#1A365D,stroke:#CBD5E0,stroke-width:1px
    classDef exito       fill:#38A169,color:#FFFFFF,stroke:#2F855A,stroke-width:2px
    classDef peligro     fill:#E53E3E,color:#FFFFFF,stroke:#C53030,stroke-width:2px
    classDef doc         fill:#2D3748,color:#FFFFFF,stroke:#1A202C,stroke-width:1px
    classDef nuevo       fill:#BEE3F8,color:#1A365D,stroke:#3182CE,stroke-width:2px

    linkStyle default color:#1A365D

    INICIO(["📋 Cliente interesado\nen comprar / alquilar"]):::naranja

    %% ── FORMULARIO ÚNICO
    subgraph FORMULARIO["📝  FORMULARIO FT-AC-001 v2.0"]
        direction TB
        F1["I. Información General\nRazón social · NIT · Ciudad · Dirección"]:::doc
        F2["II. Información de Contacto\nEncargado pagos · Recepción facturas"]:::doc
        F3["III. Referencias Bancarias\nBanco · Sucursal · Contacto (x2)"]:::doc
        F4["IV. Referencias Comerciales\nNombre · Tel · Cel (x2)"]:::doc
        F5["V. Información Tributaria\nCódigo ICA · CIIU · Rte. Fuente · IVA"]:::doc
        F6["VI. Información Contable\nFechas y horarios de radicación facturas\n⚠️ Tipo dominio correo:\nCorporativo = triple check DIAN automático\nPúblico (Gmail/Hotmail) = llamada por Cartera"]:::nuevo
        F7["VII. Socios y Accionistas\nNombre · ID · PEP >5% capital"]:::doc
        F8["VIII. Información de Obra\nNombre · Dirección · Encargado"]:::doc
        F9["IX. Autorización\nCentrales de Riesgo (Ley 1581/2012)"]:::doc
    end

    %% ── DOCUMENTOS ADJUNTOS
    subgraph DOCS["📂  DOCUMENTOS ADJUNTOS (Checklist)"]
        direction LR
        D1["📄 RUT"]:::grisClaro
        D2["📄 Cámara de Comercio"]:::grisClaro
        D3["📄 Cédula Rep. Legal"]:::grisClaro
        D4["📄 Estados Financieros"]:::grisClaro
        D5["📄 Autorización\nCentrales de Riesgo"]:::grisClaro
        D6["📄 Carta\nPresentación"]:::grisClaro
    end

    %% ── REVISIÓN SIMULTÁNEA
    subgraph APROBACION["✅  APROBACIÓN SIMULTÁNEA — 3 Áreas"]
        direction LR

        subgraph CONTA["📊 CONTABILIDAD"]
            CA1["Validación\nfinanciera\ny de crédito"]:::grisClaro
            CA2{"Favorable /\nNo Favorable"}:::naranja
            CA3["💬 Comentario\nobligatorio"]:::grisClaro
        end

        subgraph JURI["⚖️ JURÍDICA"]
            JA1["Validación\ndocumental\nListas LAFT"]:::grisClaro
            JA2{"Favorable /\nNo Favorable"}:::naranja
            JA3["💬 Comentario\nobligatorio"]:::grisClaro
        end

        subgraph COMERC["💼 COMERCIAL"]
            CO1["Evaluación\nde la oportunidad\nde negocio"]:::grisClaro
            CO2{"Favorable /\nNo Favorable"}:::naranja
            CO3["💬 Comentario\nobligatorio"]:::grisClaro
        end
    end

    CONSOLIDAR{"¿Los 3 conceptos\nson Favorables?"}:::naranja

    APROBADO["✅ Cliente APROBADO\nEstado → Activo\nNotificación automática"]:::exito
    RECHAZADO["❌ Cliente RECHAZADO\nNotificación con motivos\nal equipo comercial"]:::peligro

    CEO_OVER["🏗️ CEO / Ingeniero\nPuede forzar la aprobación\nbajo su responsabilidad\n(acceso a motivos de rechazo)"]:::nuevo

    CONTRATO["📝 Siguiente Paso:\nOrden de Compra\n+ Firma Contrato"]:::azul

    NOTIF["🔔 Notificación Automática\na todas las áreas\npara agilizar aprobación"]:::grisClaro

    %% ── FLUJO
    INICIO --> F1
    F1 --> F2 --> F3 --> F4 --> F5 --> F6 --> F7 --> F8 --> F9
    F9 --> D1 & D2 & D3 & D4 & D5 & D6

    D1 & D2 & D3 & D4 & D5 & D6 --> CA1 & JA1 & CO1
    CA1 --> CA2 --> CA3
    JA1 --> JA2 --> JA3
    CO1 --> CO2 --> CO3

    CA3 & JA3 & CO3 --> CONSOLIDAR
    CONSOLIDAR -->|"Sí — todos favorables"| APROBADO
    CONSOLIDAR -->|"No — al menos uno no favorable"| RECHAZADO
    RECHAZADO -.->|"Revisión por CEO"| CEO_OVER
    CEO_OVER -.->|"Forzar aprobación si aplica"| APROBADO
    APROBADO --> CONTRATO
    CONSOLIDAR -.->|"Pendientes sin resolver"| NOTIF
    NOTIF -.->|"Empujar a las áreas"| CA1 & JA1 & CO1
