    %% ── FLUJO PRINCIPAL ──
    INICIO --> COT_CREAR

    %% FASE 1: COTIZACIÓN
    COT_CREAR --> COT_APROBAR
    COT_APROBAR --> COT_SIIGO

    COT_SIIGO -->|"Enviar"| COT_SIIGO_ENVIO
    COT_SIIGO -->|"No enviar"| COT_NO_ENVIO

    COT_SIIGO_ENVIO --> COT_SIIGO_OK
    COT_SIIGO_OK --> PED_CREAR
    COT_NO_ENVIO --> PED_CREAR

    %% FASE 2: PEDIDO
    PED_CREAR --> PED_VERIFICAR
    PED_VERIFICAR --> PED_ESTADO

    PED_ESTADO -->|"100%"| PED_COMPLETO
    PED_ESTADO -->|"< 100%"| PED_PARCIAL

    PED_COMPLETO --> PED_SIIGO_ENVIO
    PED_PARCIAL --> PED_SIIGO_ENVIO

    PED_SIIGO_ENVIO --> REM_SALIDA

    %% FASE 3: REMISIÓN
    REM_SALIDA --> REM_ENTREGA
    REM_ENTREGA --> REM_SIIGO_SALIDA
    REM_SIIGO_SALIDA --> REM_DEVOLUCION
    REM_DEVOLUCION --> REM_SIIGO_DEVOL

    REM_SIIGO_DEVOL --> FAC_GENERAR

    %% FASE 4: FACTURACIÓN
    FAC_GENERAR --> FAC_KARDEX
    FAC_KARDEX --> FAC_VALIDAR
    FAC_VALIDAR --> FAC_SIIGO_ENVIO

    FAC_SIIGO_ENVIO --> FAC_SIIGO_VALIDA

    FAC_SIIGO_VALIDA -->|"Error"| FAC_SIIGO_ERROR
    FAC_SIIGO_VALIDA -->|"OK"| FAC_SIIGO_OK

    FAC_SIIGO_ERROR --> FAC_VALIDAR
    FAC_SIIGO_OK --> FAC_DIAN_TRANSMISION

    FAC_DIAN_TRANSMISION --> VAL_AUTO_1H

    %% FASE 5: VALIDACIÓN DIAN
    VAL_AUTO_1H --> VAL_SCRAPING
    VAL_SCRAPING --> VAL_ESTADO

    VAL_ESTADO -->|"Aceptada"| VAL_ACEPTADA
    VAL_ESTADO -->|"Rechazada"| VAL_RECHAZADA
    VAL_ESTADO -->|"Pendiente"| VAL_PENDIENTE

    VAL_PENDIENTE --> VAL_NOCTURNA
    VAL_NOCTURNA --> VAL_SCRAPING

    VAL_ACEPTADA --> PAGO_CLIENTE

    %% Validación manual siempre disponible
    VAL_MANUAL -.->|"Ejecuta"| VAL_SCRAPING

    %% FASE 6: PAGOS
    PAGO_CLIENTE --> PAGO_SIIGO_REG
    PAGO_SIIGO_REG --> PAGO_CONSULTA
    PAGO_CONSULTA --> PAGO_GYH_UPDATE
    PAGO_GYH_UPDATE --> PAGO_NOTIF

    %% MONITOREO
    PAGO_NOTIF --> MON_DASHBOARD
    VAL_ACEPTADA --> MON_DASHBOARD
    VAL_RECHAZADA --> MON_ALERTAS
    FAC_SIIGO_ERROR --> MON_ALERTAS

    MON_DASHBOARD --> MON_LOGS
    MON_ALERTAS --> MON_LOGS

    %% Si factura rechazada, reinicia ciclo
    VAL_RECHAZADA -.->|"Anular y<br/>generar nueva"| FAC_GENERAR

    %% ── NOTAS TÉCNICAS ──
    NOTE_SCRAPING["💡 SCRAPING DIAN - ESPECIFICACIONES TÉCNICAS<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>Script: scraper_dian.py / scraper_dian.js<br/><br/>FLUJO:<br/>1. Autenticación en portal DIAN (cookies/session)<br/>2. Buscar factura por: NIT + Número + Fecha<br/>3. Parsear HTML/JSON de respuesta<br/>4. Extraer campos:<br/>   - Estado: Aceptada | Rechazada | Pendiente<br/>   - CUFE: código alfanumérico único<br/>   - Fecha validación DIAN<br/>   - Motivo rechazo (si aplica)<br/>5. Registrar en BD: tabla validaciones_dian_log<br/>6. Actualizar tabla facturas<br/><br/>FRECUENCIAS:<br/>• +1 hora post-envío (automático)<br/>• Diario 2:00 AM (pendientes)<br/>• Manual on-demand<br/><br/>REINTENTOS:<br/>• Max 3 intentos si falla<br/>• Espera exponencial: 5min, 15min, 30min<br/>• Alerta si 3 fallos consecutivos<br/><br/>TECNOLOGÍAS:<br/>• Python: BeautifulSoup + Selenium + requests<br/>• Node: Puppeteer + Cheerio<br/>• Almacenar capturas de pantalla como evidencia"]:::nuevo

    NOTE_API_SIIGO["💡 API SIIGO - ENDPOINTS CLAVE<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>Base URL: https://api.siigo.com/v1<br/><br/>AUTENTICACIÓN:<br/>POST /auth → Bearer Token (renovar cada 24h)<br/><br/>ENDPOINTS:<br/>• POST /quotations → Enviar cotización<br/>• POST /invoices → Enviar factura<br/>• GET /invoices/{id}/payments → Consultar pagos<br/>• POST /credit-notes → Notas crédito (anulaciones)<br/>• GET /customers/{nit} → Validar cliente<br/><br/>WEBHOOKS (ideal):<br/>• invoice.validated → DIAN aceptó/rechazó<br/>• payment.received → Cliente pagó<br/>• invoice.status_changed → Cambio de estado<br/><br/>HEADERS REQUERIDOS:<br/>Authorization: Bearer {token}<br/>Content-Type: application/json<br/>Partner-Id: {partner_id_gyh}"]:::siigo

    NOTE_VALIDACIONES["⚠️ VALIDACIONES CRÍTICAS PRE-ENVÍO<br/>━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━<br/>ANTES de enviar a Siigo, validar:<br/><br/>1. CLIENTE:<br/>   • NIT existe en Siigo<br/>   • Régimen IVA coincide<br/>   • Datos fiscales actualizados<br/><br/>2. CENTRO DE COSTO:<br/>   • NO mezclar 13 y 14 en misma factura<br/>   • Transporte siempre factura separada<br/>   • Validar tipo de item vs centro costo<br/><br/>3. RETENCIONES:<br/>   • Alquiler: Rte. Fuente 3.5% + Rte. ICA 0.8%<br/>   • Transporte: Rte. Fuente 1%<br/>   • Venta: Rte. Fuente 2.5%<br/>   • NO aplicar si cliente régimen simplificado<br/><br/>4. ITEMS:<br/>   • Códigos de producto existen en Siigo<br/>   • Unidades de medida correctas<br/>   • Precios > 0<br/>   • IVA correcto (19% si aplica)<br/><br/>5. NUMERACIÓN:<br/>   • Consecutivo único no repetido<br/>   • Rango autorizado DIAN vigente"]:::peligro

    VAL_SCRAPING -.-> NOTE_SCRAPING
    FAC_SIIGO_ENVIO -.-> NOTE_API_SIIGO
    FAC_VALIDAR -.-> NOTE_VALIDACIONES
