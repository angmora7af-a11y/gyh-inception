%%{init: {
  'theme': 'base',
  'themeVariables': {
    'primaryColor': '#1A365D',
    'primaryTextColor': '#FFFFFF',
    'primaryBorderColor': '#1A365D',
    'lineColor': '#4A5568',
    'secondaryColor': '#EDF2F7',
    'clusterBkg': '#2D3748',
    'clusterBorder': '#1A365D',
    'titleColor': '#FFFFFF',
    'edgeLabelBackground': '#F7FAFC',
    'fontFamily': 'Montserrat, sans-serif'
  }
}}%%

graph LR
    classDef rol        fill:#1A365D,color:#FFFFFF,stroke:#0F2440,stroke-width:3px,font-weight:bold
    classDef modulo     fill:#4A5568,color:#FFFFFF,stroke:#2D3748,stroke-width:2px
    classDef accion     fill:#EDF2F7,color:#1A365D,stroke:#CBD5E0,stroke-width:1px
    classDef critico    fill:#FF9F1C,color:#1A365D,stroke:#E8910A,stroke-width:2px
    classDef admin      fill:#38A169,color:#FFFFFF,stroke:#2F855A,stroke-width:3px

    %% ── ROLES
    R_CEO["🏗️ INGENIERO/CEO\nAprobación final · Veto"]:::critico
    R_ADMIN["👑 ADMIN"]:::admin
    R_COM["💼 COMERCIAL"]:::rol
    R_DIB["✏️ DIBUJANTE"]:::rol
    R_CONT["📊 CONTABILIDAD"]:::rol
    R_JUR["⚖️ JURÍDICA"]:::rol
    R_ALM["🏭 ALMACÉN"]:::rol
    R_COND["🚛 CONDUCTOR"]:::rol

    %% ── MÓDULOS Y ACCIONES

    subgraph MOD_CLI["👥 Módulo Clientes"]
        MC1["Ver prospectos"]:::accion
        MC2["Crear / Editar cliente"]:::accion
        MC3["Subir documentos"]:::accion
        MC4["Dar concepto favorable / no favorable"]:::critico
        MC5["Ver todos los conceptos"]:::accion
        MC6["Aprobar cliente (solo si los 3 dan favorable)"]:::critico
    end

    subgraph MOD_COT["📋 Módulo Cotizaciones"]
        CQ1["Ver cotizaciones asignadas"]:::accion
        CQ2["Cargar planos y archivos"]:::accion
        CQ3["Crear cotización técnica (materiales)"]:::accion
        CQ4["Agregar valores comerciales"]:::accion
        CQ5["Generar PDF y enviar al cliente"]:::accion
        CQ6["Ver todas las cotizaciones"]:::accion
    end

    subgraph MOD_CONT["📝 Módulo Contratos"]
        CT1["Crear orden de compra"]:::accion
        CT2["Enviar contrato a firma"]:::accion
        CT3["Confirmar firma del contrato"]:::accion
    end

    subgraph MOD_INV["📦 Módulo Inventarios"]
        IV1["Ver stock y Kardex"]:::accion
        IV2["Generar remisión de salida"]:::accion
        IV3["Programar agenda de transporte"]:::accion
        IV4["Asignar conductor y vehículo"]:::accion
        IV5["Confirmar entrega / recepción"]:::accion
        IV6["Ver agenda asignada"]:::accion
    end

    subgraph MOD_FAC["💳 Módulo Facturación"]
        FA1["Generar factura"]:::accion
        FA2["Registrar pagos"]:::accion
        FA3["Gestionar cartera"]:::accion
        FA4["Ver facturas propias"]:::accion
    end

    subgraph MOD_AUD["🔍 Auditoría y Config"]
        AU1["Ver log completo de auditoría"]:::critico
        AU2["Gestionar usuarios y roles"]:::critico
        AU3["Configurar catálogo de productos"]:::critico
        AU4["Ver motivos de rechazo detallados"]:::critico
        AU5["Forzar aprobación de cliente (bajo su responsabilidad)"]:::critico
    end

    %% ── PERMISOS POR ROL
    R_CEO --- MC1 & MC5 & MC6
    R_CEO --- AU1 & AU4 & AU5

    R_ADMIN --- MC1 & MC2 & MC4 & MC5 & MC6
    R_ADMIN --- CQ5 & CQ6
    R_ADMIN --- CT1 & CT2 & CT3
    R_ADMIN --- IV1 & IV2 & IV3 & IV4
    R_ADMIN --- FA1 & FA2 & FA3
    R_ADMIN --- AU1 & AU2 & AU3

    R_COM --- MC1 & MC2 & MC3 & MC5
    R_COM --- CQ4 & CQ5 & CQ6
    R_COM --- CT1 & CT2

    R_DIB --- CQ1 & CQ2 & CQ3
    R_DIB --- MC1

    R_CONT --- MC1 & MC4 & MC5
    R_CONT --- FA1 & FA2 & FA3 & FA4
    R_CONT --- AU1

    R_JUR --- MC1 & MC4 & MC5
    R_JUR --- CT3
    R_JUR --- FA3 & FA4

    R_ALM --- IV1 & IV2 & IV3 & IV4 & IV5
    R_ALM --- MC1

    R_COND --- IV6 & IV5
