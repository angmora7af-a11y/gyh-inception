%%{init: {
  'theme': 'base',
  'themeVariables': {
    'primaryColor': '#1A365D',
    'primaryTextColor': '#FFFFFF',
    'primaryBorderColor': '#1A365D',
    'lineColor': '#4A5568',
    'secondaryColor': '#EDF2F7',
    'clusterBkg': '#2D3748',
    'clusterBorder': '#1A365D',
    'titleColor': '#FFFFFF',
    'edgeLabelBackground': '#F7FAFC',
    'fontFamily': 'Montserrat, sans-serif'
  }
}}%%

flowchart TD
    classDef modulo  fill:#1A365D,color:#FFFFFF,stroke:#2C5282,stroke-width:2px,font-weight:bold
    classDef pagina  fill:#EDF2F7,color:#1A365D,stroke:#CBD5E0,stroke-width:1px
    classDef cta     fill:#FF9F1C,color:#1A365D,stroke:#E8910A,stroke-width:2px,font-weight:bold
    classDef alerta  fill:#E53E3E,color:#FFFFFF,stroke:#C53030,stroke-width:1px
    classDef exito   fill:#38A169,color:#FFFFFF,stroke:#2F855A,stroke-width:1px
    classDef nuevo   fill:#BEE3F8,color:#1A365D,stroke:#3182CE,stroke-width:1px

    INV["📦 Almacén / Gestión de Conductores\n/almacen"]:::modulo

    subgraph S_STOCK["STOCK Y KARDEX"]
        INV_STOCK["🗄️ Stock Total (Momento Cero)\n/almacen/stock\nBodega + En Clientes + En Producción\n⚠️ Sin inventario físico estandarizado\n(catálogos — saldos negativos visibles)"]:::pagina
        INV_PROD["🏭 Equipos en Producción\n/almacen/produccion"]:::pagina
        INV_STOCK --> INV_PROD
    end

    subgraph S_PEDIDOS["PEDIDOS"]
        INV_PED["📋 Pedidos\n/almacen/pedidos"]:::nuevo
        INV_PED_NEW["➕ Nuevo Pedido\n/almacen/pedidos/nuevo\nObra · Frente · Ítems · Cantidades"]:::cta
        INV_PED_DET["🔍 Detalle Pedido\n/almacen/pedidos/:id\nEstado: Pendiente · Parcial · Completo"]:::nuevo
        INV_CANCEL["❌ Cancelación de Pedido\n/almacen/pedidos/:id/cancelar\nMotivo · Notificación Ingeniería"]:::alerta
        INV_PED --> INV_PED_NEW & INV_PED_DET
        INV_PED_DET --> INV_CANCEL
    end

    subgraph S_REM["REMISIONES"]
        INV_REM["📤 Remisiones\n/almacen/remisiones"]:::pagina
        INV_REM_NEW["➕ Nueva Remisión de Salida\n/almacen/remisiones/nueva\nPedido · Fecha · Hora · Conductor · Obra\n(¿Es parcial? — acumula hasta completar)"]:::cta
        INV_DEV["📥 Devoluciones / Entrada\n/almacen/devoluciones"]:::pagina
        INV_INSP["🔍 Inspección de Equipos\n/almacen/devoluciones/:id/inspeccion\n5 estados por ítem:"]:::nuevo
        INV_OK["✅ Buen Estado"]:::exito
        INV_DAN["⚠️ Dañado"]:::alerta
        INV_MANT["🔧 Mantenimiento\n(G&H asume costo)"]:::nuevo
        INV_FALT["❌ Faltante\n→ genera Reposición"]:::alerta
        INV_AJENO["↩️ Equipo Ajeno\n→ registrar y devolver"]:::nuevo
        INV_REM --> INV_REM_NEW
        INV_REM --> INV_DEV
        INV_DEV --> INV_INSP
        INV_INSP --> INV_OK & INV_DAN & INV_MANT & INV_FALT & INV_AJENO
    end

    subgraph S_VER["VERIFICACIÓN 3 FUENTES"]
        INV_VF["🔍 Verificación Cruzada\n/almacen/devoluciones/:id/verificar\nFormato Conductor\nFormato Despachador\nFotos Portería Obra"]:::nuevo
        INV_AJUSTE["⚖️ Ajuste de Inventario\n/almacen/ajustes\nCruzar frentes / sucursales\n(equipo prestado entre frentes)"]:::nuevo
        INV_VF --> INV_AJUSTE
    end

    subgraph S_LOGISTICA["LOGÍSTICA Y CONDUCTORES"]
        INV_AGENDA["🗓️ Agenda de Transporte\n/almacen/agenda\nFecha · Hora · Vehículo · Dirección"]:::cta
        INV_COND["🚛 Gestión de Conductores\n/almacen/conductores\nAgenda · Historial · Disponibilidad"]:::pagina
        INV_COND_INDISP["⚠️ Indisponibilidad Conductor\n/almacen/conductores/:id/indisponibilidad\nMotivo: mantenimiento · reposición · otro\nFechas desde/hasta"]:::nuevo
        INV_TRAY["🗺️ Cálculo de Trayecto\n/almacen/conductores/:id/trayecto\nPunto recogida → destino\n― Distancia km (configurable)\n― Regla combustible\n― Peso y volumen del camión"]:::nuevo
        INV_ALERTA["🔔 Alertas de Recogidas Pendientes\n/almacen/alertas\nOptimización de rutas"]:::alerta
        INV_AGENDA --> INV_COND
        INV_COND --> INV_COND_INDISP & INV_TRAY
    end

    subgraph S_CRONOGRAMA["CRONOGRAMA DIARIO — RECEPCIÓN"]
        INV_CRONO["🗓️ Cronograma Diario\n/almacen/cronograma\nViviana: Obra · Cliente · N° corte · Fecha"]:::nuevo
        INV_CRONO_REP["📤 Reporte de Recogidas\n/almacen/cronograma/reporte\nAlmacén reporta realizadas vs. programadas"]:::nuevo
        INV_CRONO --> INV_CRONO_REP
    end

    subgraph S_AJENOS["EQUIPOS AJENOS"]
        INV_AJENOS_LIST["↩️ Equipos Ajenos en Bodega\n/almacen/equipos-ajenos\nEmpresa propietaria · Estado · Devolución"]:::nuevo
    end

    subgraph S_CONSUMIBLES["CONSUMIBLES — MATERIALES BODEGA"]
        INV_CONS["📦 Kardex de Consumibles\n/almacen/consumibles\nPINTURA · DISOLVENTE · SOLDADURA\nTORNILLOS · GASES · OTROS"]:::nuevo
        INV_CONS_CAT["🗂️ Catálogo de Consumibles\n/almacen/consumibles/catalogo\nNombre · Unidad · Bodega · Stock Min/Max"]:::pagina
        INV_CONS_MOV["➕ Registrar Movimiento\n/almacen/consumibles/:id/movimiento\nEntrada · Salida · Documento · Observaciones"]:::cta
        INV_CONS_ALERTA["🔔 Alertas de Stock Mínimo\n/almacen/consumibles/alertas\nProductos bajo nivel mínimo"]:::alerta
        INV_CONS --> INV_CONS_CAT & INV_CONS_MOV & INV_CONS_ALERTA
    end

    subgraph S_CONFIG["CONFIGURACIÓN ALMACÉN (SuperAdmin)"]
        INV_CONF_TARIFA["⚙️ Tarifas de Transporte\n/almacen/config/tarifas\nBogotá $2.500/ton · Fuera $4.500/ton\nTipo cálculo: mayor(peso,volumen)"]:::nuevo
        INV_CONF_CRIT["✅ Criterios Liquidación Conductores\n/almacen/config/criterios-conductor\nMP · RTE · SER · CL · PP\nActivar/desactivar por período"]:::nuevo
        INV_CONF_PESOS["⚖️ Catálogo de Pesos por Equipo\n/almacen/config/pesos-catalogo\nFT · FM · AMD · ALFOR\n(fuente: PESO-EQUIPOS-GYH.xlsx)"]:::nuevo
    end

    INV --> S_STOCK & S_PEDIDOS & S_REM & S_VER & S_LOGISTICA & S_CRONOGRAMA & S_AJENOS & S_CONSUMIBLES & S_CONFIG
